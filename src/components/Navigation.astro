---
const { current = '' } = Astro.props;
const links = [
  { href: '/journal', label: 'Journal' },
  { href: '/manifesto', label: 'Manifesto', hideOnMobile: true },
  { href: '/system', label: 'System' },
  { href: '/agents', label: 'Agents' },
  { href: '/intel', label: 'Intel' },
  { href: '/token', label: 'Token' },
  { href: 'https://x.com/squaer_agent', label: 'Dispatch ↗', external: true, hideOnMobile: true },
];
---

<nav class="nav desktop-nav">
  <a href="/" class="nav-logo" aria-label="SQUAER">
    <svg viewBox="0 0 28 28" width="28" height="28" class="glyph-logo" fill="currentColor">
      <!-- S glyph mark — signal pulse -->
      <rect x="4" y="4" width="20" height="4"/>
      <rect x="4" y="4" width="4" height="10"/>
      <rect x="4" y="12" width="20" height="4"/>
      <rect x="20" y="16" width="4" height="8"/>
      <rect x="4" y="20" width="20" height="4"/>
    </svg>
  </a>
  <div class="nav-links">
    {links.map(link => (
      <a href={link.href} class:list={[current === link.href ? 'active' : '', link.hideOnMobile ? 'hide-mobile' : '']} {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}>
        {link.label}
      </a>
    ))}
  </div>
</nav>

<style>
  @media (max-width: 768px) {
    .nav-links .hide-mobile {
      display: none;
    }
  }
</style>
