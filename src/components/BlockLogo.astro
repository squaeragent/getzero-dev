---
/**
 * SQUAER logo — oh-my-logo ASCII art, font-size fitted by JS clone measurement
 */
---

<div class="block-logo-wrap">
  <div class="block-logo crt-boot" role="img" aria-label="SQUAER">
<pre class="logo-art">███████╗  ██████╗  ██╗   ██╗  █████╗  ███████╗ ██████╗
██╔════╝ ██╔═══██╗ ██║   ██║ ██╔══██╗ ██╔════╝ ██╔══██╗
███████╗ ██║   ██║ ██║   ██║ ███████║ █████╗   ██████╔╝
╚════██║ ██║▄▄ ██║ ██║   ██║ ██╔══██║ ██╔══╝   ██╔══██╗
███████║ ╚██████╔╝ ╚██████╔╝ ██║  ██║ ███████╗ ██║  ██║
╚══════╝  ╚══▀▀═╝   ╚═════╝  ╚═╝  ╚═╝ ╚══════╝ ╚═╝  ╚═╝</pre>
    <div class="crt-scanline"></div>
  </div>
</div>

<style>
  .block-logo-wrap {
    width: 100%;
    overflow: hidden;
    /* height set by JS after font measurement */
  }

  .block-logo {
    position: relative;
    display: inline-block;
    cursor: pointer;
    /* CRT animation only — NO transform here (set by JS on wrap instead) */
  }

  .logo-art {
    font-family: var(--font-head, 'JetBrains Mono', monospace);
    font-size: 16px; /* JS will override */
    line-height: 1.2;
    color: var(--phosphor, #c8ff00);
    text-shadow: 0 0 8px rgba(200,255,0,0.6), 0 0 20px rgba(200,255,0,0.2);
    white-space: pre;
    display: block;
    /* No overflow:hidden here — JS needs scrollWidth to return actual text width */
    overflow: visible;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    animation: logoFadeIn 0.5s ease-out 0.65s both;
  }

  @keyframes logoFadeIn {
    0%   { opacity: 0; filter: brightness(4) blur(2px); }
    50%  { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }

  /* CRT boot on the inner div (separate from any JS transforms on wrap) */
  .crt-boot {
    animation: crtExpand 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  @keyframes crtExpand {
    0%   { transform: scaleY(0.04); filter: brightness(5) blur(4px); }
    25%  { transform: scaleY(0.04); }
    60%  { transform: scaleY(1.04); filter: brightness(1.4); }
    80%  { transform: scaleY(0.98); }
    100% { transform: scaleY(1);   filter: brightness(1); }
  }

  .crt-scanline {
    position: absolute;
    inset: 0; height: 3px; width: 100%;
    background: linear-gradient(180deg, transparent, rgba(200,255,0,0.6), transparent);
    top: 50%; opacity: 0; pointer-events: none;
    animation: scanSweep 0.45s ease-out 0.25s both;
  }
  @keyframes scanSweep {
    0%   { top: 50%; opacity: 0.9; }
    60%  { top: 5%;  opacity: 0.4; }
    100% { top: -5%; opacity: 0; }
  }

  @keyframes logoBreath {
    0%, 100% { text-shadow: 0 0 8px rgba(200,255,0,0.6), 0 0 20px rgba(200,255,0,0.2); }
    50%       { text-shadow: 0 0 14px rgba(200,255,0,0.35), 0 0 35px rgba(200,255,0,0.1); }
  }
  .block-logo.breathing .logo-art {
    animation: logoBreath 4s ease-in-out infinite;
  }

  @media (hover: hover) {
    .block-logo:hover .logo-art {
      text-shadow: 0 0 12px rgba(200,255,0,0.9), 0 0 32px rgba(200,255,0,0.5);
      transition: text-shadow 0.25s ease;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .crt-boot, .logo-art, .crt-scanline { animation: none; }
    .block-logo.breathing .logo-art { animation: none; }
  }
</style>

<script>
  (function () {
    const logo = document.querySelector('.block-logo') as HTMLElement;
    const pre  = document.querySelector('.logo-art')  as HTMLElement;
    const wrap = document.querySelector('.block-logo-wrap') as HTMLElement;
    if (!logo || !pre || !wrap) return;

    const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!REDUCED) setTimeout(() => logo.classList.add('breathing'), 1800);
    logo.addEventListener('click', () => { window.location.href = '/token'; });

    // ── Font-size fitting via off-DOM clone ──
    // Clone with max-content width + overflow:visible so scrollWidth = true text width
    async function fitFontSize() {
      await (document as any).fonts.ready;

      // Measure at 100px using off-screen clone with NO overflow/width constraints
      const clone = pre.cloneNode(true) as HTMLElement;
      clone.style.cssText = [
        'position:fixed',
        'top:-99999px',
        'left:-99999px',
        'visibility:hidden',
        'pointer-events:none',
        'font-size:100px',
        'white-space:pre',
        'width:max-content',   // shrink-wrap to text width, NOT viewport
        'max-width:none',
        'overflow:visible',    // return full text width in scrollWidth
        'display:block',
      ].join(';');

      document.body.appendChild(clone);
      const textWidth100 = clone.scrollWidth;
      document.body.removeChild(clone);

      if (!textWidth100 || !wrap.clientWidth) return;

      // font-size = 100px * (available / measuredWidth), capped at 28px desktop
      const available = wrap.clientWidth;
      const optimal = Math.min(100 * (available / textWidth100), 28);
      pre.style.fontSize = Math.max(optimal, 5) + 'px';
    }

    fitFontSize();
    window.addEventListener('resize', fitFontSize);
  })();
</script>
