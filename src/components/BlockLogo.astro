<style>
  .block-logo {
    position: relative;
    display: inline-block;
    overflow: hidden;
    cursor: pointer;
  }

  .logo-art {
    font-family: var(--font-head, 'JetBrains Mono', monospace);
    color: var(--phosphor, #c8ff00);
    text-shadow: 0 0 8px rgba(200, 255, 0, 0.6), 0 0 20px rgba(200, 255, 0, 0.25);
    font-size: clamp(9px, 2.4vw, 20px);
    line-height: 1.2;
    white-space: pre;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    animation: blockMaterialize 0.6s ease-out 0.6s both;
  }

  @keyframes blockMaterialize {
    0%   { opacity: 0; filter: brightness(4) blur(2px); }
    40%  { opacity: 0.6; filter: brightness(2) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1) blur(0); }
  }

  /* ‚ĒÄ‚ĒÄ CRT POWER-ON ‚ĒÄ‚ĒÄ */
  .crt-boot {
    animation: crtExpand 0.65s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  @keyframes crtExpand {
    0%   { transform: scaleY(0.04); filter: brightness(5) blur(4px); }
    25%  { transform: scaleY(0.04); }
    55%  { transform: scaleY(1.03); filter: brightness(1.4); }
    80%  { transform: scaleY(0.98); }
    100% { transform: scaleY(1);   filter: brightness(1); }
  }

  /* Scanline sweep */
  .crt-scanline {
    position: absolute;
    inset: 0;
    height: 4px;
    width: 100%;
    background: linear-gradient(180deg, transparent, rgba(200,255,0,0.55), transparent);
    top: 50%;
    opacity: 0;
    pointer-events: none;
    animation: scanSweep 0.5s ease-out 0.3s both;
  }

  @keyframes scanSweep {
    0%   { top: 50%; opacity: 0.85; }
    60%  { top: 5%;  opacity: 0.4; }
    100% { top: -5%; opacity: 0; }
  }

  /* ‚ĒÄ‚ĒÄ BREATHING ‚ĒÄ‚ĒÄ */
  @keyframes logoBreath {
    0%, 100% { opacity: 1; text-shadow: 0 0 8px rgba(200,255,0,0.6), 0 0 20px rgba(200,255,0,0.25); }
    50%       { opacity: 0.82; text-shadow: 0 0 12px rgba(200,255,0,0.4), 0 0 30px rgba(200,255,0,0.15); }
  }

  .block-logo.breathing .logo-art {
    animation: logoBreath 4s ease-in-out infinite;
  }

  /* Hover glow */
  @media (hover: hover) {
    .block-logo:hover .logo-art {
      text-shadow: 0 0 12px rgba(200,255,0,0.9), 0 0 30px rgba(200,255,0,0.5);
      transition: text-shadow 0.3s ease;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .crt-boot, .logo-art, .crt-scanline { animation: none; }
    .block-logo.breathing .logo-art { animation: none; }
  }
</style>

<script>
  (function() {
    const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const logo = document.querySelector('.block-logo');
    if (!logo) return;

    if (!REDUCED) {
      setTimeout(() => logo.classList.add('breathing'), 1800);
    }

    logo.addEventListener('click', () => { window.location.href = '/token'; });
  })();
</script>
