<style>
  .block-logo-wrap {
    width: 100%;
    overflow: hidden;
  }

  .block-logo {
    position: relative;
    display: inline-block;
    cursor: pointer;
  }

  .logo-art {
    font-family: var(--font-head, 'JetBrains Mono', monospace);
    /*
      Pure CSS fit formula ‚ÄĒ no JS, no measurement.
      Longest line: 54 chars. JetBrains Mono char ratio: ~0.607.
      Container = viewport - 30px (margins + border + padding).
      font-size = (vw - 30px) / (54 √ó 0.607) = (vw - 30) / 32.8
      Use 34 as divisor (safety buffer ~3%).
      clamp(8px floor, calculated, 28px desktop cap)
    */
    font-size: clamp(8px, calc((100vw - 30px) / 34), 28px);
    line-height: 1.2;
    color: var(--phosphor, #33ff66);
    text-shadow: 0 0 8px rgba(200,255,0,0.6), 0 0 20px rgba(200,255,0,0.2);
    white-space: pre;
    display: block;
    overflow: visible;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    animation: logoFadeIn 0.5s ease-out 0.65s both;
  }

  @keyframes logoFadeIn {
    0%   { opacity: 0; filter: brightness(4) blur(2px); }
    50%  { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }

  .crt-boot {
    animation: crtExpand 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  @keyframes crtExpand {
    0%   { transform: scaleY(0.04); filter: brightness(5) blur(4px); }
    25%  { transform: scaleY(0.04); }
    60%  { transform: scaleY(1.04); filter: brightness(1.4); }
    80%  { transform: scaleY(0.98); }
    100% { transform: scaleY(1);   filter: brightness(1); }
  }

  .crt-scanline {
    position: absolute;
    inset: 0; height: 3px; width: 100%;
    background: linear-gradient(180deg, transparent, rgba(200,255,0,0.6), transparent);
    top: 50%; opacity: 0; pointer-events: none;
    animation: scanSweep 0.45s ease-out 0.25s both;
  }
  @keyframes scanSweep {
    0%   { top: 50%; opacity: 0.9; }
    60%  { top: 5%;  opacity: 0.4; }
    100% { top: -5%; opacity: 0; }
  }

  @keyframes logoBreath {
    0%, 100% { text-shadow: 0 0 8px rgba(200,255,0,0.6), 0 0 20px rgba(200,255,0,0.2); }
    50%       { text-shadow: 0 0 14px rgba(200,255,0,0.35), 0 0 35px rgba(200,255,0,0.1); }
  }
  .block-logo.breathing .logo-art {
    animation: logoBreath 4s ease-in-out infinite;
  }

  @media (hover: hover) {
    .block-logo:hover .logo-art {
      text-shadow: 0 0 12px rgba(200,255,0,0.9), 0 0 32px rgba(200,255,0,0.5);
      transition: text-shadow 0.25s ease;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .crt-boot, .logo-art, .crt-scanline { animation: none; }
    .block-logo.breathing .logo-art { animation: none; }
  }
</style>

<script>
  (function () {
    const logo = document.querySelector('.block-logo') as HTMLElement;
    if (!logo) return;
    const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!REDUCED) setTimeout(() => logo.classList.add('breathing'), 1800);
    logo.addEventListener('click', () => { window.location.href = '/token'; });
  })();
</script>
