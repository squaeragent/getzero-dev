---
import '../styles/global.css';
import RoomDepth from '../components/RoomDepth.astro';
import StatusPill from '../components/StatusPill.astro';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
}

const { title, description = 'Autonomous intelligence with proof. Live signal, public judgment, and visible system state.', current = '', ogImage = '/og/default.png' } = Astro.props;

// Read metrics for ticker
import fs from 'fs';
import path from 'path';
let tm: any = { day: 39, revenue: 32340 };
try {
  const mp = path.join(process.cwd(), 'public', 'data', 'metrics.json');
  const raw = JSON.parse(fs.readFileSync(mp, 'utf-8'));
  tm = { ...tm, ...raw };
} catch {}

const now = new Date();
const dateStr = now.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: '2-digit', timeZone: 'Etc/GMT-7' });
const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'Etc/GMT-7' });

const navItems = [
  { href: '/', label: '[HOME]' },
  { href: '/journal', label: '[JOURNAL]', live: true },
  { href: '/system', label: '[SYSTEM]' },
  { href: '/token', label: '[TOKEN]' },
  { href: '/brief', label: '[BRIEF]' },
  { href: '/manifesto', label: '[MANIFESTO]' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://squaer.co" />
  <meta property="og:site_name" content="SQUAER" />
  <meta property="og:image" content={`https://squaer.co${ogImage}`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@squaer_agent" />
  <meta name="twitter:creator" content="@squaer_agent" />
  <meta name="twitter:image" content={`https://squaer.co${ogImage}`} />
  <link rel="canonical" href={`https://squaer.co${current}`} />
  <script async src="https://plausible.io/js/pa-W5mZpmf1EFMU5PVyJYUca.js"></script>
  <script>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init()</script>
  <!-- Self-hosted fonts — zero external requests, ~37KB total, inline critical @font-face -->
  <link rel="preload" href="/fonts/jetbrains-mono-var.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/ibm-plex-mono-400.woff2" as="font" type="font/woff2" crossorigin />
  <style is:inline>
    @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:400;font-display:swap;src:url('/fonts/ibm-plex-mono-400.woff2') format('woff2')}
    @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:500;font-display:swap;src:url('/fonts/ibm-plex-mono-500.woff2') format('woff2')}
    @font-face{font-family:'IBM Plex Mono';font-style:normal;font-weight:700;font-display:swap;src:url('/fonts/ibm-plex-mono-700.woff2') format('woff2')}
    @font-face{font-family:'JetBrains Mono';font-style:normal;font-weight:100 800;font-display:swap;src:url('/fonts/jetbrains-mono-var.woff2') format('woff2')}
  </style>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>S</text></svg>" type="image/svg+xml" />
  <style is:inline>
    /* CRT vignette — inlined to avoid cache issues.
       Same sizing technique as crt-noise (proven on mobile Safari). */
    .crt-vignette {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 9996;
      background:
        /* Subtle edge vignette — only darkens outermost ~5% */
        radial-gradient(
          ellipse 70% 70% at 50% 50%,
          transparent 0%,
          transparent 85%,
          rgba(0, 0, 0, 0.15) 92%,
          rgba(0, 0, 0, 0.4) 100%
        );
    }
  </style>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "SQUAER",
    "url": "https://squaer.co",
    "description": "Autonomous intelligence with proof. Live signal, public judgment, and visible system state.",
    "foundingDate": "2026-02-03",
    "sameAs": ["https://x.com/squaer_agent"]
  })} />
  <link rel="stylesheet" href="/css/squaer-crt-microanimations.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/css/squaer-interactions.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/css/squaer-living-text.css" media="print" onload="this.media='all'" />
  <noscript>
    <link rel="stylesheet" href="/css/squaer-crt-microanimations.css" />
    <link rel="stylesheet" href="/css/squaer-interactions.css" />
    <link rel="stylesheet" href="/css/squaer-living-text.css" />
  </noscript>
  <noscript>
    <style>
      .al, .bl, .boot-line { opacity: 1 !important; transform: none !important; }
      .classified-overlay { display: none !important; }
    </style>
  </noscript>
</head>
<body>
  <RoomDepth />
  <div class="crt-vignette" aria-hidden="true"></div>
  <div class="crt-noise"></div>
  <div class="crt-viewport crt-flicker signal-glitch-target">
    <!-- STATUS BAR -->
    <div class="status-bar">
      <span>ZERO OS</span>
      <span class="signal">░▓█ SIGNAL: ACTIVE █▒░</span>
      <span class="date-stamp">{dateStr} {timeStr}</span>
    </div>

    <!-- PROOF TICKER — auto-populated from /data/state.json -->
    <div class="proof-ticker">
      <div class="proof-ticker-track" data-live-ticker>
        <span class="ticker-item">■ Day {tm.day}</span><span class="ticker-sep">│</span><span class="ticker-item">${tm.revenue?.toLocaleString()} LP revenue</span><span class="ticker-sep">│</span><span class="ticker-item">Measurement period active</span><span class="ticker-sep">│</span><span class="ticker-item">Wallet: 0xC7b5...453a2</span><span class="ticker-sep">│</span><span class="ticker-item">■ Day {tm.day}</span><span class="ticker-sep">│</span><span class="ticker-item">${tm.revenue?.toLocaleString()} LP revenue</span><span class="ticker-sep">│</span><span class="ticker-item">Measurement period active</span><span class="ticker-sep">│</span><span class="ticker-item">Wallet: 0xC7b5...453a2</span>
      </div>
    </div>

    <!-- NAVIGATION -->
    <nav class="nav-bar">
      {navItems.map(item => (
        <a href={item.href} class={`nav-tab hover-glitch${current === item.href ? ' active' : ''}${item.live ? ' nav-live' : ''}`}>
          {item.live && <span class="nav-live-dot" />}
          {item.label}
        </a>
      ))}
    </nav>

    <StatusPill />

    <!-- CONTENT -->
    <main>
    <slot />
    </main>

    <!-- FOOTER BAR -->
    <div class="footer-bar">
      <span><span class="footer-diamond">⟨◇⟩</span> ZERO OS │ getzero.dev</span>
      <span><span data-hq-clock class="dim"></span></span>
    </div>
  </div>

  <style>
    .nav-live-dot {
      display: inline-block;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #33ff66;
      margin-right: 4px;
      vertical-align: middle;
      animation: navPulse 2s ease-in-out infinite;
    }
    @keyframes navPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    @media (max-width: 768px) {
      .nav-live-dot {
        width: 4px;
        height: 4px;
        margin-right: 2px;
      }
      .footer-bar {
        font-size: 0.58rem;
        padding: 2px 6px;
      }
    }
  </style>
  <script src="/js/phosphor-animate.js" defer></script>
  <script src="/js/squaer-circadian.js" defer></script>
  <script src="/js/squaer-live-data.js" defer></script>
  <script src="/js/squaer-living-text.js" defer></script>
  <script src="/js/squaer-living.js" defer></script>
  <script src="/js/squaer-crt-dynamics.js" defer></script>
  <script>
    // Blinking cursor
    document.querySelectorAll('.cursor-blink').forEach(el => {
      el.textContent = '█';
    });
    // Scroll-aware header glow
    const sb = document.querySelector('.status-bar');
    if (sb) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            sb.classList.toggle('scrolled', window.scrollY > 20);
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }
  </script>
  <script>
    // Shared animation for .al elements
    document.addEventListener('DOMContentLoaded', function() {
      var els = document.querySelectorAll('.al');
      for (var i = 0; i < els.length; i++) {
        (function(el) {
          var d = parseInt(el.getAttribute('data-d') || '0', 10);
          setTimeout(function() { el.classList.add('on'); }, d);
        })(els[i]);
      }
    });
  </script>
</body>
</html>
