---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageWrapper from '../components/ui/PageWrapper.astro';
import HazardDivider from '../components/ui/HazardDivider.astro';

const tiers = [
  { name: 'PUBLIC', amount: '0', access: 'Site, system pages, public proof, selected artifacts', status: 'LIVE' },
  { name: 'SIGNAL', amount: 'TBD', access: 'Deeper intelligence artifacts and early access drops', status: 'DESIGNING' },
  { name: 'OPERATOR', amount: 'TBD', access: 'Priority access, deeper system visibility, experimental utilities', status: 'DESIGNING' },
  { name: 'BUILDER', amount: 'TBD', access: 'Highest-context participation layer for future tools and coordination', status: 'LATER' },
];
---

<BaseLayout title="Access — SQUAER" description="How participation works in SQUAER: what is public, what will be gated, and why $SQUAER matters." current="/access" ogImage="/og/default.png">

<PageWrapper>

<pre class="term-block al" data-d="0"><span class="phosphor">squaer $</span> access --explain</pre>

<h1 class="access-title al" data-d="200">ACCESS</h1>
<p class="access-sub al" data-d="300">Participation logic for the SQUAER system.</p>

<HazardDivider variant="section" text="PUBLIC VS GATED" color="phosphor" />

<div class="access-section al" data-d="400">
  <p><span class="phosphor">Public</span> is where SQUAER proves itself: the site, the system surface, the journal, and selected artifacts.</p>
  <p><span class="phosphor">Gated</span> is where access starts to compound: deeper intelligence artifacts, earlier drops, and higher-context participation.</p>
  <p>The goal is not to hide everything. The goal is to make holding <a href="/token" class="phosphor-link">$SQUAER</a> create real advantage over time.</p>
</div>

<HazardDivider variant="warning" text="ACCESS LADDER" color="amber" />

<div class="tier-grid al" data-d="500">
  {tiers.map(t => (
    <div class="tier-cell">
      <div class="tier-header">
        <span class="tier-name">{t.name}</span>
        <span class={`tier-status ${t.status === 'LIVE' ? 'phosphor' : 'dim'}`}>[{t.status}]</span>
      </div>
      <div class="tier-amount">{t.amount} <span class="dim">SQUAER</span></div>
      <div class="tier-access dim">{t.access}</div>
    </div>
  ))}
</div>

<HazardDivider variant="section" text="CURRENT STATE" color="phosphor" />

<div class="connect-section al" data-d="600">
  <button class="connect-btn" disabled>
    WALLET GATING NOT LIVE YET
  </button>
  <p class="connect-note dim">No fake access theater: wallet connection and tier checks are not shipped yet.</p>
  <p class="connect-note dim">What exists now is the public layer. What comes next is real gated utility, not placeholder buttons.</p>
  <p class="connect-note dim"><a href="/token" class="phosphor-link">Read the token thesis →</a></p>
</div>

<pre class="term-block al" data-d="700">
<span class="dim">// public.access = LIVE
// gated.access = DESIGNING
// wallet.verification = NOT_SHIPPED</span>

<span class="phosphor">squaer $</span> <span class="terminal-cursor">█</span></pre>

</PageWrapper>

</BaseLayout>

<style>
  .access-title {
    font-family: var(--font-head);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
    margin: var(--sp-8) 0 var(--sp-4);
    line-height: 1.1;
  }
  .access-sub {
    font-family: var(--font-body);
    font-size: var(--size-md);
    color: var(--text-dim);
    margin: 0 0 var(--sp-12);
  }
  .access-section p {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0 0 1em;
    max-width: 62ch;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin: var(--sp-8) 0 var(--sp-16);
  }
  .tier-cell {
    background: var(--bg);
    padding: var(--sp-10);
  }
  .tier-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--sp-4);
  }
  .tier-name {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-base);
    color: var(--text);
  }
  .tier-status {
    font-family: var(--font-head);
    font-size: var(--size-xs);
    font-weight: 700;
  }
  .tier-amount {
    font-family: var(--font-head);
    font-size: var(--size-md);
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
    margin-bottom: var(--sp-4);
  }
  .tier-access {
    font-family: var(--font-body);
    font-size: var(--size-xs);
    line-height: 1.4;
  }

  .connect-section {
    padding: var(--sp-12) 0 var(--sp-16);
    text-align: center;
  }
  .connect-btn {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-md);
    color: var(--bg);
    background: var(--phosphor);
    padding: var(--sp-8) var(--sp-16);
    border: none;
    letter-spacing: 0.05em;
    cursor: not-allowed;
    opacity: 0.65;
  }
  .connect-note {
    font-family: var(--font-body);
    font-size: var(--size-sm);
    margin-top: var(--sp-8);
  }

  .phosphor { color: var(--phosphor); text-shadow: var(--glow-phosphor); }
  .dim { color: var(--text-dim); }
  .phosphor-link { color: var(--phosphor); text-decoration: none; }
  .phosphor-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
</style>
