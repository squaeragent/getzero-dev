---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageWrapper from '../components/ui/PageWrapper.astro';
import HazardDivider from '../components/ui/HazardDivider.astro';

const tiers = [
  { name: 'FREE', amount: '0', access: 'Public feed, site access', status: 'LIVE' },
  { name: 'SIGNAL', amount: '1,000,000', access: 'Intelligence brief, signal alerts', status: 'COMING' },
  { name: 'OPERATOR', amount: '10,000,000', access: 'Priority intelligence, API access', status: 'COMING' },
  { name: 'BUILDER', amount: '100,000,000', access: 'Full system access, governance weight', status: 'COMING' },
];
---

<BaseLayout title="Access — SQUAER Intelligence" description="Token-gated access to SQUAER intelligence tiers. Hold $SQUAER to unlock." current="/access" ogImage="/og/default.png">

<PageWrapper>

<pre class="term-block al" data-d="0"><span class="phosphor">squaer $</span> access --check-tier</pre>

<h1 class="access-title al" data-d="200">ACCESS</h1>
<p class="access-sub al" data-d="300">Token-gated intelligence is coming.</p>

<HazardDivider variant="section" text="HOW IT WORKS" color="phosphor" />

<div class="access-section al" data-d="400">
  <p>Hold $SQUAER in your wallet. The more you hold, the more you unlock. No subscriptions. No invoices. Just tokens and access.</p>
  <p>Tier verification will check your wallet balance against the thresholds below. Connect once, access persists as long as you hold.</p>
</div>

<HazardDivider variant="warning" text="ACCESS TIERS" color="amber" />

<div class="tier-grid al" data-d="500">
  {tiers.map(t => (
    <div class="tier-cell">
      <div class="tier-header">
        <span class="tier-name">{t.name}</span>
        <span class={`tier-status ${t.status === 'LIVE' ? 'phosphor' : 'dim'}`}>[{t.status}]</span>
      </div>
      <div class="tier-amount">{t.amount} <span class="dim">SQUAER</span></div>
      <div class="tier-access dim">{t.access}</div>
    </div>
  ))}
</div>

<HazardDivider variant="section" text="CONNECT" color="phosphor" />

<div class="connect-section al" data-d="600">
  <button class="connect-btn" disabled>
    CONNECT WALLET
  </button>
  <p class="connect-note dim">Wallet connection coming soon. Tier verification is under development.</p>
  <p class="connect-note dim">In the meantime, <a href="/token" class="phosphor-link">get $SQUAER</a> to prepare for launch.</p>
</div>

<pre class="term-block al" data-d="700">
<span class="dim">// access.tier = PENDING
// wallet.connected = false
// status: BUILDING</span>

<span class="phosphor">squaer $</span> <span class="terminal-cursor">█</span></pre>

</PageWrapper>

</BaseLayout>

<style>
  .access-title {
    font-family: var(--font-head);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
    margin: var(--sp-8) 0 var(--sp-4);
    line-height: 1.1;
  }
  .access-sub {
    font-family: var(--font-body);
    font-size: var(--size-md);
    color: var(--text-dim);
    margin: 0 0 var(--sp-12);
  }
  .access-section p {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0 0 1em;
    max-width: 62ch;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin: var(--sp-8) 0 var(--sp-16);
  }
  .tier-cell {
    background: var(--bg);
    padding: var(--sp-10);
  }
  .tier-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--sp-4);
  }
  .tier-name {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-base);
    color: var(--text);
  }
  .tier-status {
    font-family: var(--font-head);
    font-size: var(--size-xs);
    font-weight: 700;
  }
  .tier-amount {
    font-family: var(--font-head);
    font-size: var(--size-md);
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
    margin-bottom: var(--sp-4);
  }
  .tier-access {
    font-family: var(--font-body);
    font-size: var(--size-xs);
    line-height: 1.4;
  }

  .connect-section {
    padding: var(--sp-12) 0 var(--sp-16);
    text-align: center;
  }
  .connect-btn {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-md);
    color: var(--bg);
    background: var(--phosphor);
    padding: var(--sp-8) var(--sp-16);
    border: none;
    letter-spacing: 0.05em;
    cursor: not-allowed;
    opacity: 0.5;
  }
  .connect-note {
    font-family: var(--font-body);
    font-size: var(--size-sm);
    margin-top: var(--sp-8);
  }

  .phosphor { color: var(--phosphor); text-shadow: var(--glow-phosphor); }
  .dim { color: var(--text-dim); }
  .phosphor-link { color: var(--phosphor); text-decoration: none; }
  .phosphor-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .tier-grid { grid-template-columns: 1fr; }
  }
</style>
