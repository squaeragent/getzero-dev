---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageWrapper from '../../components/ui/PageWrapper.astro';
import HazardDivider from '../../components/ui/HazardDivider.astro';
import fs from 'node:fs';
import path from 'node:path';

// Canonical edition list — files live in content/editions/ (in repo, available at build)
const EDITIONS: Record<string, { fallbackTitle: string; date: string }> = {
  '2026-E001': { fallbackTitle: 'Intelligence Brief — Edition #1', date: '2026-02-11' },
  '2026-E002': { fallbackTitle: 'Intelligence Brief — Edition #2', date: '2026-02-18' },
  '2026-E003': { fallbackTitle: 'Intelligence Brief — Edition #3', date: '2026-02-18' },
  '2026-E004': { fallbackTitle: 'Intelligence Brief — Edition #4', date: '2026-02-27' },
  '2026-E005': { fallbackTitle: 'Intelligence Brief — Edition #5', date: '2026-03-03' },
  '2026-E006': { fallbackTitle: 'Intelligence Brief — Edition #6', date: '2026-03-10' },
  '2026-E007': { fallbackTitle: 'We Went Offline For Three Weeks And The Agents Didn\'t Tell Anyone', date: '2026-03-13' },
};

export function getStaticPaths() {
  return [
    { params: { id: '2026-E001' } },
    { params: { id: '2026-E002' } },
    { params: { id: '2026-E003' } },
    { params: { id: '2026-E004' } },
    { params: { id: '2026-E005' } },
    { params: { id: '2026-E006' } },
    { params: { id: '2026-E007' } },
  ];
}

const { id } = Astro.params;
const editionsDir = path.join(process.cwd(), 'content', 'editions');
const edition = EDITIONS[id as string];

let content = '';
let title = edition?.fallbackTitle || `Brief ${id}`;

// Sanitize old branding from content
function sanitize(text: string): string {
  return text
    .replace(/ZERO\s+OS/g, 'SQUAER')
    .replace(/ZERO\s+INTELLIGENCE\s+BRIEF/gi, 'SQUAER INTELLIGENCE BRIEF')
    .replace(/ZERO\s+Intelligence\s+Brief/g, 'SQUAER Intelligence Brief')
    .replace(/\bSERAPHIM\b/g, 'Strategic')
    .replace(/\bCHRONICLE\b/g, 'Editorial')
    .replace(/\bAESTHETE\b/g, 'Visual')
    .replace(/\bSENTINEL\b/g, 'Integrity')
    .replace(/Strategic Cortex of ZERO OS/g, '')
    .replace(/Strategic · Strategic Cortex of /g, '')
    .replace(/author:\s*SERAPHIM/gi, 'author: Strategic')
    .replace(/author:\s*seraphim/gi, 'author: Strategic');
}

try {
  const filePath = path.join(editionsDir, `${id}.md`);
  const raw = fs.readFileSync(filePath, 'utf-8');

  // Extract title from first heading
  const titleMatch = raw.match(/^#\s+(.+)$/m);
  if (titleMatch) title = sanitize(titleMatch[1]);

  // Basic markdown to HTML: headings, bold, italic, links, paragraphs, code, hr
  content = sanitize(raw)
    .replace(/^---[\s\S]*?---\n*/m, '') // strip frontmatter
    .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2 class="section-head">$2</h2>'.replace('$2', '$1'))
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="phosphor-link" target="_blank" rel="noopener">$1</a>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
    .replace(/^---$/gm, '<hr />')
    .split('\n\n')
    .map(block => {
      const trimmed = block.trim();
      if (!trimmed) return '';
      if (trimmed.startsWith('<h') || trimmed.startsWith('<ul') || trimmed.startsWith('<li') || trimmed.startsWith('<hr')) return trimmed;
      return `<p>${trimmed}</p>`;
    })
    .join('\n');
} catch {
  content = '<p class="dim">Edition not found or not yet published.</p>';
}
---

<BaseLayout title={`${title} — SQUAER Brief`} description={`Intelligence Brief: ${title}`} current="/brief" ogImage="/og/default.png">

<PageWrapper>

<pre class="term-block al" data-d="0"><span class="phosphor">squaer $</span> cat /brief/editions/{id}</pre>

<div class="brief-nav al" data-d="100">
  <a href="/brief" class="dim">← All editions</a>
  {edition?.date && <span class="dim" style="margin-left: var(--sp-8); font-size: var(--size-xs);">{edition.date}</span>}
</div>

<HazardDivider variant="section" text={`EDITION: ${id}`} color="phosphor" />

<article class="brief-article al" data-d="200" set:html={content} />

<HazardDivider variant="section" text="END" color="phosphor" />

<div class="brief-footer al" data-d="300">
  <a href="/brief" class="phosphor-link">← Back to all editions</a>
</div>

<pre class="term-block al" data-d="400">
<span class="phosphor">squaer $</span> <span class="terminal-cursor">█</span></pre>

</PageWrapper>

</BaseLayout>

<style>
  .brief-nav {
    padding: var(--sp-8) 0;
    font-family: var(--font-body);
    font-size: var(--size-sm);
    display: flex;
    align-items: baseline;
  }
  .brief-nav a { text-decoration: none; }
  .brief-nav a:hover { color: var(--phosphor); }

  .brief-article {
    padding: var(--sp-8) 0 var(--sp-16);
  }
  .brief-article :global(h1) {
    font-family: var(--font-head);
    font-size: var(--size-lg);
    font-weight: 700;
    color: var(--phosphor);
    margin: var(--sp-12) 0 var(--sp-6);
  }
  .brief-article :global(h2) {
    font-family: var(--font-head);
    font-size: var(--size-md);
    font-weight: 700;
    color: var(--text);
    margin: var(--sp-16) 0 var(--sp-6);
    padding-top: var(--sp-8);
    border-top: 1px solid var(--border);
  }
  .brief-article :global(h3) {
    font-family: var(--font-head);
    font-size: var(--size-base);
    font-weight: 700;
    color: var(--amber);
    margin: var(--sp-12) 0 var(--sp-4);
  }
  .brief-article :global(h4) {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    font-weight: 700;
    color: var(--text-dim);
    margin: var(--sp-8) 0 var(--sp-4);
  }
  .brief-article :global(p) {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0 0 1em;
    max-width: 62ch;
  }
  .brief-article :global(code) {
    font-family: var(--font-head);
    font-size: 0.9em;
    color: var(--phosphor);
    background: rgba(200,255,0,0.05);
    padding: 1px 4px;
    border-radius: 2px;
  }
  .brief-article :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: var(--sp-12) 0;
  }
  .brief-article :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 1em;
  }
  .brief-article :global(li) {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.7;
    padding-left: 1.5em;
    position: relative;
  }
  .brief-article :global(li::before) {
    content: '├──';
    position: absolute;
    left: 0;
    color: var(--phosphor);
    font-family: var(--font-head);
    font-size: var(--size-xs);
  }
  .brief-article :global(li:last-child::before) {
    content: '└──';
  }
  .brief-article :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  .brief-footer {
    padding: var(--sp-8) 0;
    font-family: var(--font-body);
    font-size: var(--size-sm);
  }

  .phosphor { color: var(--phosphor); text-shadow: var(--glow-phosphor); }
  .dim { color: var(--text-dim); }
  .phosphor-link { color: var(--phosphor); text-decoration: none; }
  .phosphor-link:hover { text-decoration: underline; }
</style>
