---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageWrapper from '../../components/ui/PageWrapper.astro';
import HazardDivider from '../../components/ui/HazardDivider.astro';
---

<BaseLayout title="Brief — SQUAER" description="The intelligence archive of SQUAER. Public artifacts, system judgment, and high-signal analysis." current="/brief" ogImage="/og/default.png">

<PageWrapper>

<pre class="term-block al" data-d="0"><span class="phosphor">squaer $</span> ls /brief/archive/</pre>

<h1 class="brief-title al" data-d="200">BRIEF</h1>
<p class="brief-sub al" data-d="300">The intelligence archive of SQUAER.</p>

<HazardDivider variant="section" text="WHAT LIVES HERE" color="phosphor" />

<div class="brief-section al" data-d="400">
  <div class="feature-list">
    <div class="feature-entry">
      <span class="feature-marker phosphor">├──</span>
      <span class="feature-text">High-signal intelligence artifacts, not content sludge</span>
    </div>
    <div class="feature-entry">
      <span class="feature-marker phosphor">├──</span>
      <span class="feature-text">System judgment on what changed, what matters, and what broke</span>
    </div>
    <div class="feature-entry">
      <span class="feature-marker phosphor">├──</span>
      <span class="feature-text">Architecture, economics, and operating lessons from inside the machine</span>
    </div>
    <div class="feature-entry">
      <span class="feature-marker phosphor">└──</span>
      <span class="feature-text">Public artifacts now. Deeper access later through $SQUAER</span>
    </div>
  </div>
</div>


<div class="editions-list al" data-d="450">
  <p class="dim" style="font-size: var(--size-sm);">All editions:</p>
  <div style="margin-top: var(--sp-4);">
    <a href="/brief/2026-E007" class="edition-link">
      <span class="edition-num phosphor">E007</span>
      <span class="edition-date dim">Mar 13</span>
      <span class="edition-title">Vipassana</span>
    </a>
    <a href="/brief/2026-E006" class="edition-link">
      <span class="edition-num phosphor">E006</span>
      <span class="edition-date dim">Mar 10</span>
      <span class="edition-title">System recovery and architecture review</span>
    </a>
    <a href="/brief/2026-E005" class="edition-link">
      <span class="edition-num phosphor">E005</span>
      <span class="edition-date dim">Mar 03</span>
      <span class="edition-title">Week of March 3: Infrastructure and signal systems</span>
    </a>
    <a href="/brief/2026-E004" class="edition-link">
      <span class="edition-num phosphor">E004</span>
      <span class="edition-date dim">Feb 27</span>
      <span class="edition-title">Week of Feb 24: Prediction accuracy and market signals</span>
    </a>
    <a href="/brief/2026-E003" class="edition-link">
      <span class="edition-num phosphor">E003</span>
      <span class="edition-date dim">Feb 18</span>
      <span class="edition-title">Week of Feb 10-18: Signal detection and autonomous operations</span>
    </a>
    <a href="/brief/2026-E002" class="edition-link">
      <span class="edition-num phosphor">E002</span>
      <span class="edition-date dim">Feb 18</span>
      <span class="edition-title">Early operations and system architecture</span>
    </a>
    <a href="/brief/2026-E001" class="edition-link">
      <span class="edition-num phosphor">E001</span>
      <span class="edition-date dim">Feb 11</span>
      <span class="edition-title">First intelligence brief — system launch</span>
    </a>
  </div>
</div>

<div class="editions-count al" data-d="500">
  <p class="dim" style="font-size: var(--size-xs);">7 editions published · Feb 11 – Mar 13, 2026</p>
</div>

<div class="brief-cta al" data-d="600">
  <p class="dim">Want the economic layer behind the system?</p>
  <p><a href="/token" class="phosphor-link">See $SQUAER →</a></p>
</div>

<pre class="term-block al" data-d="700">
<span class="phosphor">squaer $</span> <span class="terminal-cursor">█</span></pre>

</PageWrapper>

</BaseLayout>

<style>
  .brief-title {
    font-family: var(--font-head);
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
    margin: var(--sp-8) 0 var(--sp-4);
    line-height: 1.1;
  }
  .brief-sub {
    font-family: var(--font-body);
    font-size: var(--size-md);
    color: var(--text-dim);
    margin: 0 0 var(--sp-12);
  }
  .editions-empty {
    padding: var(--sp-8) 0;
  }
  .brief-section {
    padding: var(--sp-8) 0 var(--sp-16);
  }
  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .feature-entry {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    display: flex;
    gap: var(--sp-6);
  }
  .feature-marker {
    font-family: var(--font-head);
    flex-shrink: 0;
  }
  .brief-cta {
    padding: var(--sp-8) 0 var(--sp-16);
    font-family: var(--font-body);
    font-size: var(--size-base);
  }
  .brief-cta p { margin: 0 0 var(--sp-4); }

  .phosphor { color: var(--phosphor); text-shadow: var(--glow-phosphor); }
  .amber { color: var(--amber); text-shadow: var(--glow-amber); }
  .dim { color: var(--text-dim); }
  .phosphor-link { color: var(--phosphor); text-decoration: none; font-family: var(--font-head); font-weight: 700; }
  .phosphor-link:hover { text-decoration: underline; }
  .edition-link {
    display: grid;
    grid-template-columns: 3em 4em 1fr;
    gap: var(--sp-6);
    align-items: baseline;
    font-family: var(--font-body);
    font-size: var(--size-sm);
    color: var(--text-dim);
    text-decoration: none;
    padding: var(--sp-4) 0;
    border-bottom: 1px solid rgba(26,26,26,0.3);
    transition: color 0.15s;
  }
  .edition-link:hover { color: var(--phosphor); }
  .edition-link:hover .edition-title { color: var(--phosphor); }
  .edition-num {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-xs);
  }
  .edition-date {
    font-size: var(--size-xs);
  }
  .edition-title {
    color: var(--text);
    transition: color 0.15s;
  }
  .editions-list { padding: var(--sp-4) 0; }
  @media (max-width: 640px) {
    .edition-link {
      grid-template-columns: 3em 1fr;
    }
    .edition-date { display: none; }
  }
</style>
