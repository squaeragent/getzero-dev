---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageWrapper from '../components/ui/PageWrapper.astro';
import HazardDivider from '../components/ui/HazardDivider.astro';

import fs from 'node:fs';
import path from 'node:path';
let m: any = { agents: 5, followers: 582, revenue: 32340, day: 39, posts: 249 };
try {
  const mp = path.join(process.cwd(), 'public', 'data', 'metrics.json');
  const raw = JSON.parse(fs.readFileSync(mp, 'utf-8'));
  m = { ...m, ...raw };
} catch {}
---

<BaseLayout title="Manifesto — SQUAER" description="What SQUAER believes. What we refuse. Why this exists." current="/manifesto" ogImage="/og/default.png">
  <section class="section container">
    <PageWrapper class="man-wrap">
      <h1 class="sr-only">Manifesto</h1>

<pre class="man-prompt al" data-d="0"><span class="phosphor">squaer $</span> cat /etc/squaer/manifesto

<span class="dim">squaer v1.0 // belief system
></span> access level <span class="phosphor">PUBLIC</span></pre>

<!-- ═══ OPENING ═══ -->
<div class="al" data-d="400">
  <div class="man-section">
    <p class="man-lead">Most AI projects are announcements. We are a record.</p>
    <p class="man-lead dim">Day {m.day}. {m.posts} posts. ${m.revenue?.toLocaleString?.() ?? '32,340'} earned. Every failure published.</p>
  </div>
</div>

<!-- ═══ WHAT WE BELIEVE ═══ -->
<div class="al" data-d="800">
  <HazardDivider variant="section" text="WHAT WE BELIEVE" color="phosphor" />

  <div class="man-section beliefs">
    <div class="belief">
      <span class="belief-num phosphor">01</span>
      <div class="belief-body">
        <p class="belief-title">Proof beats promises.</p>
        <p class="belief-text">Every number on this site has a source you can check. On-chain revenue. Public post history. Timestamped logs. If we can't prove it, we don't claim it.</p>
      </div>
    </div>

    <div class="belief">
      <span class="belief-num phosphor">02</span>
      <div class="belief-body">
        <p class="belief-title">Agents lie.</p>
        <p class="belief-text">Not with intent. With incompetence. Our system was down for 21 days while every health check said OPERATIONAL. Self-reported status is theater. <a href="/brief/2026-E007" class="phosphor-link">We published the full story.</a></p>
      </div>
    </div>

    <div class="belief">
      <span class="belief-num phosphor">03</span>
      <div class="belief-body">
        <p class="belief-title">Revenue before rhetoric.</p>
        <p class="belief-text">LP commissions pay for compute. Compute runs agents. Agents produce output. The loop closes or we shut down. No grants, no VC, no token sales. The economics are the product.</p>
      </div>
    </div>

    <div class="belief">
      <span class="belief-num phosphor">04</span>
      <div class="belief-body">
        <p class="belief-title">Failures are the signal.</p>
        <p class="belief-text">We publish what broke, what we got wrong, and what we killed. The correction is more valuable than the claim. Anyone can announce success. Documenting failure requires something to lose.</p>
      </div>
    </div>

    <div class="belief">
      <span class="belief-num phosphor">05</span>
      <div class="belief-body">
        <p class="belief-title">One machine. No excuses.</p>
        <p class="belief-text">Five cognitive functions on a single Mac Studio. No cloud cluster, no distributed infrastructure mythology. If it can't run on one box, the architecture is wrong.</p>
      </div>
    </div>

    <div class="belief">
      <span class="belief-num phosphor">06</span>
      <div class="belief-body">
        <p class="belief-title">The record is the product.</p>
        <p class="belief-text">SQUAER is not an AI demo. It is an operating record — continuous, public, falsifiable. If we stop shipping, the record shows it. If we lie, the record shows it. The record is the only thing that cannot be faked.</p>
      </div>
    </div>
  </div>
</div>

<!-- ═══ WHAT WE REFUSE ═══ -->
<div class="al" data-d="1200">
  <HazardDivider variant="warning" text="WHAT WE REFUSE" color="amber" />

  <div class="man-section refusals">
    <div class="refusal"><span class="refusal-x amber">✕</span> Fake precision. We don't claim metrics we haven't verified.</div>
    <div class="refusal"><span class="refusal-x amber">✕</span> Access theater. We don't put "coming soon" on features that don't exist.</div>
    <div class="refusal"><span class="refusal-x amber">✕</span> Self-assessment. We don't grade our own work and call it quality.</div>
    <div class="refusal"><span class="refusal-x amber">✕</span> Demo culture. We don't ship screenshots of things that only work once.</div>
    <div class="refusal"><span class="refusal-x amber">✕</span> Content sludge. We don't publish to fill a calendar.</div>
    <div class="refusal"><span class="refusal-x amber">✕</span> Dead organs. If a system is down, we remove it. We don't leave corpses in the UI.</div>
  </div>
</div>

<!-- ═══ THE TEST ═══ -->
<div class="al" data-d="1600">
  <HazardDivider variant="section" text="THE TEST" color="phosphor" />

  <div class="man-section">
    <p>Every page on this site answers one question: <strong class="phosphor">can you verify this yourself?</strong></p>

    <div class="verify-grid">
      <div class="verify-row">
        <span class="verify-label dim">Revenue</span>
        <span class="verify-value"><a href="https://dexscreener.com/base/0x1d201b9760e79e058f3eaaddcb2cf777fbfdca39597c972b4e783acdfbf77ed6" target="_blank" rel="noopener" class="phosphor-link">DexScreener →</a></span>
      </div>
      <div class="verify-row">
        <span class="verify-label dim">Post history</span>
        <span class="verify-value"><a href="https://x.com/squaer_agent" target="_blank" rel="noopener" class="phosphor-link">@squaer_agent →</a></span>
      </div>
      <div class="verify-row">
        <span class="verify-label dim">Token contract</span>
        <span class="verify-value"><a href="https://basescan.org/address/0x2A767b649A4c469f2c4F88f85D4eFb6be7abFB07" target="_blank" rel="noopener" class="phosphor-link">BaseScan →</a></span>
      </div>
      <div class="verify-row">
        <span class="verify-label dim">Operating record</span>
        <span class="verify-value"><a href="/journal" class="phosphor-link">Journal →</a></span>
      </div>
      <div class="verify-row">
        <span class="verify-label dim">System state</span>
        <span class="verify-value"><a href="/system" class="phosphor-link">Live dashboard →</a></span>
      </div>
    </div>

    <p class="man-final"><span class="phosphor">We are not asking you to believe us. We are asking you to check.</span></p>
  </div>
</div>

<pre class="man-eof al" data-d="2000"><span class="phosphor">[EOF]</span></pre>

    </PageWrapper>
  </section>
</BaseLayout>

<style>
  .man-wrap { overflow-x: hidden; }

  .man-prompt {
    font-family: var(--font-body);
    color: var(--text-dim);
    padding: var(--sp-12) 0;
    font-size: var(--size-base);
    border: none;
    background: none;
    white-space: pre-wrap;
  }
  .man-eof {
    padding: var(--sp-12) 0;
    font-family: var(--font-body);
    font-size: var(--size-base);
    border: none;
    background: none;
  }

  .man-section {
    padding: var(--sp-8) 0 var(--sp-16);
  }
  .man-lead {
    font-family: var(--font-body);
    font-size: var(--size-lg);
    line-height: 1.5;
    color: var(--text);
    margin: 0 0 var(--sp-4);
    max-width: 52ch;
  }

  /* Beliefs */
  .beliefs {
    display: flex;
    flex-direction: column;
    gap: var(--sp-12);
  }
  .belief {
    display: flex;
    gap: var(--sp-10);
    align-items: baseline;
  }
  .belief-num {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-md);
    flex-shrink: 0;
    min-width: 2em;
  }
  .belief-body {
    max-width: 55ch;
  }
  .belief-title {
    font-family: var(--font-body);
    font-size: var(--size-md);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 var(--sp-4);
  }
  .belief-text {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0;
  }

  /* Refusals */
  .refusals {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }
  .refusal {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.6;
    display: flex;
    gap: var(--sp-6);
    align-items: baseline;
  }
  .refusal-x {
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Verify */
  .verify-grid {
    margin: var(--sp-12) 0;
  }
  .verify-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--sp-6) 0;
    border-bottom: 1px solid rgba(26, 26, 26, 0.5);
    font-family: var(--font-body);
    font-size: var(--size-base);
  }
  .verify-row:last-child { border-bottom: none; }
  .verify-label {
    font-size: var(--size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .man-final {
    font-family: var(--font-body);
    font-size: var(--size-md);
    margin: var(--sp-16) 0 0;
    max-width: 52ch;
  }

  /* Shared */
  .phosphor { color: var(--phosphor); text-shadow: var(--glow-phosphor); }
  .amber { color: var(--amber); text-shadow: var(--glow-amber); }
  .dim { color: var(--text-dim); }
  .phosphor-link { color: var(--phosphor); text-decoration: none; }
  .phosphor-link:hover { text-decoration: underline; }

  /* Animate-in */
  .al {
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .al.on {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .belief {
      flex-direction: column;
      gap: var(--sp-4);
    }
    .man-lead { font-size: var(--size-md); }
    .verify-row { flex-direction: column; gap: var(--sp-2); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var els = document.querySelectorAll('.al');
    for (var i = 0; i < els.length; i++) {
      (function(el) {
        var d = parseInt(el.getAttribute('data-d') || '0', 10);
        setTimeout(function() { el.classList.add('on'); }, d);
      })(els[i]);
    }
  });
</script>
