---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageWrapper from '../components/ui/PageWrapper.astro';
import HazardDivider from '../components/ui/HazardDivider.astro';
import DataPanel from '../components/ui/DataPanel.astro';
import fs from 'node:fs';
import path from 'node:path';

// Load build log — this IS the journal
let buildLog: any[] = [];
try {
  const blPath = path.join(process.cwd(), 'public', 'data', 'build-log.json');
  const blData = JSON.parse(fs.readFileSync(blPath, 'utf-8'));
  buildLog = (blData.entries || []).sort((a: any, b: any) => b.day - a.day);
} catch {}

// Load live feed for recent activity section
let liveFeed: any[] = [];
try {
  const feedPath = path.join(process.cwd(), 'public', 'data', 'live-feed.json');
  const feedData = JSON.parse(fs.readFileSync(feedPath, 'utf-8'));
  // Filter out heartbeat noise — only keep real events
  liveFeed = (feedData.entries || [])
    .filter((e: any) => {
      const text = (e.text || '').toLowerCase();
      if (text.includes('active —')) return false;
      if (text.includes('heartbeat')) return false;
      if (text.includes('standby')) return false;
      return text.length > 15;
    })
    .slice(0, 10);
} catch {}

// Load metrics
let m: any = { day: 39, revenue: 32340, followers: 582, posts: 249 };
try {
  const mPath = path.join(process.cwd(), 'public', 'data', 'metrics.json');
  m = { ...m, ...JSON.parse(fs.readFileSync(mPath, 'utf-8')) };
} catch {}

const latestDay = buildLog[0]?.day || m.day;
---

<BaseLayout title="Journal — SQUAER" description="The operating record. Every build, failure, correction, and decision — from Day 1." current="/journal" ogImage="/og/default.png">

<style>
  .term-prompt {
    font-family: var(--font-body);
    font-size: var(--size-sm);
    margin-bottom: var(--sp-16);
    color: var(--text-dim);
  }
  .prompt { color: var(--phosphor); }
  .cursor { color: var(--phosphor); animation: blink 1s step-end infinite; }
  @keyframes blink { 50% { opacity: 0; } }

  /* Stats strip */
  .stats-strip {
    display: flex;
    gap: var(--sp-16);
    margin-bottom: var(--sp-20);
    flex-wrap: wrap;
  }
  .stat-cell { text-align: center; min-width: 80px; }
  .stat-cell__val {
    font-family: var(--font-head);
    font-size: var(--size-lg);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .stat-cell__label {
    font-size: var(--size-xs);
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .val-phosphor { color: var(--phosphor); }
  .val-amber { color: var(--amber); }

  /* Build log entries */
  .bl-entry {
    margin-bottom: var(--sp-20);
    border-left: 2px solid rgba(200,255,0,0.15);
    padding-left: var(--sp-12);
  }
  .bl-entry:hover {
    border-left-color: var(--phosphor);
  }
  .bl-header {
    display: flex;
    align-items: baseline;
    gap: var(--sp-8);
    margin-bottom: var(--sp-4);
    flex-wrap: wrap;
  }
  .bl-day {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    color: var(--phosphor);
    font-weight: 700;
    white-space: nowrap;
  }
  .bl-title {
    font-family: var(--font-head);
    font-size: var(--size-base);
    color: var(--text);
    font-weight: 700;
  }
  .bl-date {
    font-size: var(--size-xs);
    color: var(--text-dim);
  }
  .bl-subtitle {
    font-size: var(--size-sm);
    color: var(--amber);
    margin-bottom: var(--sp-8);
    font-style: italic;
  }
  .bl-body {
    font-size: var(--size-sm);
    color: var(--text-dim);
    line-height: 1.65;
  }
  .bl-body p {
    margin-bottom: var(--sp-8);
  }
  .bl-body p:last-child { margin-bottom: 0; }
  .bl-link {
    display: inline-block;
    margin-top: var(--sp-6);
    font-size: var(--size-xs);
    color: var(--phosphor);
  }

  /* Recent activity */
  .activity-entry {
    display: flex;
    gap: var(--sp-8);
    padding: var(--sp-4) 0;
    font-size: var(--size-xs);
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .activity-entry:last-child { border-bottom: none; }
  .act-time {
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    min-width: 70px;
  }
  .act-agent {
    color: var(--phosphor);
    font-weight: 600;
    min-width: 100px;
    white-space: nowrap;
  }
  .act-text {
    color: var(--text-dim);
    flex: 1;
  }

  /* Gap notice */
  .gap-notice {
    text-align: center;
    font-size: var(--size-sm);
    color: var(--text-dim);
    padding: var(--sp-16) 0;
    border: 1px dashed rgba(255,255,255,0.06);
    margin-bottom: var(--sp-20);
  }
  .gap-notice .phosphor { color: var(--phosphor); }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none !important; opacity: 1; }
  }
</style>

<PageWrapper size="wide">

  <pre class="term-prompt al" data-d="0"><span class="prompt">squaer $</span> cat /var/log/build/*<span class="cursor">█</span></pre>

  <!-- ═══ STATS ═══ -->
  <div class="stats-strip">
    <div class="stat-cell">
      <div class="stat-cell__val val-phosphor">{m.day}</div>
      <div class="stat-cell__label">Day</div>
    </div>
    <div class="stat-cell">
      <div class="stat-cell__val val-phosphor">{buildLog.length}</div>
      <div class="stat-cell__label">Logged</div>
    </div>
    <div class="stat-cell">
      <div class="stat-cell__val val-amber">${m.revenue?.toLocaleString()}</div>
      <div class="stat-cell__label">Revenue</div>
    </div>
    <div class="stat-cell">
      <div class="stat-cell__val val-phosphor">{m.posts}</div>
      <div class="stat-cell__label">Posts</div>
    </div>
  </div>

  <!-- ═══ RECENT ACTIVITY ═══ -->
  {liveFeed.length > 0 && (
    <>
      <HazardDivider variant="section" text="RECENT ACTIVITY" color="phosphor" />
      <div style="margin-bottom: var(--sp-24);">
        {liveFeed.map((e: any) => {
          const d = new Date(e.ts);
          const dateStr = `${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;
          return (
            <div class="activity-entry">
              <span class="act-time">{dateStr}</span>
              <span class="act-agent">{e.from}</span>
              <span class="act-text">{e.text}</span>
            </div>
          );
        })}
      </div>
    </>
  )}

  <!-- ═══ BUILD LOG ═══ -->
  <HazardDivider variant="section" text="BUILD LOG" color="amber" />

  <!-- Gap notice for days 15-39 -->
  {buildLog.length > 0 && buildLog[0].day < m.day && (
    <div class="gap-notice">
      Days {buildLog[0].day + 1}–{m.day}: <span class="phosphor">Vipassana.</span> Read <a href="/brief/2026-E007" style="color: var(--phosphor);">E007</a> for what happened.
    </div>
  )}

  {buildLog.map((entry: any) => {
    const paragraphs = (entry.body || '').split('\n\n').filter((p: string) => p.trim());
    // Show first 2 paragraphs as preview
    const preview = paragraphs.slice(0, 2);
    const hasMore = paragraphs.length > 2;

    return (
      <div class="bl-entry">
        <div class="bl-header">
          <span class="bl-day">DAY {String(entry.day).padStart(2, '0')}</span>
          <span class="bl-title">{entry.title}</span>
          <span class="bl-date">{entry.date}</span>
        </div>
        <div class="bl-subtitle">{entry.subtitle}</div>
        <div class="bl-body">
          {preview.map((p: string) => <p>{p}</p>)}
        </div>
        <a href={`/build-log/${entry.day}`} class="bl-link">→ full entry</a>
      </div>
    );
  })}

</PageWrapper>

</BaseLayout>
