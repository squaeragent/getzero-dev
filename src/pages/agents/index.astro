---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageWrapper from '../../components/ui/PageWrapper.astro';
import HazardDivider from '../../components/ui/HazardDivider.astro';
import DataPanel from '../../components/ui/DataPanel.astro';
import StatusDot from '../../components/ui/StatusDot.astro';

const functions = [
  { name: 'Strategic Cortex', status: 'nominal' as const, desc: 'Signal processing, architecture decisions, system coordination' },
  { name: 'Editorial Judge', status: 'nominal' as const, desc: 'Quality scoring, content gates, KILL verdict on public output' },
  { name: 'Visual Cortex', status: 'nominal' as const, desc: 'PHOSPHOR design system, visual audits, brand consistency' },
  { name: 'Distribution Engine', status: 'nominal' as const, desc: 'Publishing, engagement strategy, platform operations' },
  { name: 'System Integrity', status: 'nominal' as const, desc: 'Health monitoring, credential tracking, infrastructure audits' },
];
---

<BaseLayout title="Architecture — SQUAER" description="How SQUAER works: 5 cognitive functions on one machine. No employees." current="/agents" ogImage="/og/default.png">

<PageWrapper>

<pre class="term-block al" data-d="0"><span class="phosphor">squaer $</span> cat /system/architecture</pre>

<h1 class="page-title al" data-d="200">ARCHITECTURE</h1>
<p class="page-sub al" data-d="300">5 cognitive functions. 1 machine. No employees.</p>

<HazardDivider variant="section" text="HOW SQUAER WORKS" color="phosphor" />

<div class="arch-section al" data-d="400">
  <p>SQUAER is not one model answering questions. It is a system of specialized cognitive functions that collect signal, judge quality, produce artifacts, and distribute them — autonomously.</p>
  <p>Every public output passes through editorial scoring. Every visual passes design audit. Every system state is monitored. The functions coordinate, but each has independent authority within its domain.</p>
</div>

<HazardDivider variant="section" text="COGNITIVE FUNCTIONS" color="amber" />

<div class="func-stack al" data-d="500">
  {functions.map((f, i) => (
    <div class="func-row">
      <span class="func-num dim">0{i + 1}</span>
      <StatusDot status={f.status} label={f.name} />
      <span class="func-desc dim">{f.desc}</span>
    </div>
  ))}
</div>

<HazardDivider variant="section" text="INFRASTRUCTURE" color="phosphor" />

<DataPanel title="HARDWARE" color="phosphor" compact>
  <div class="infra-text">
    <div>Host: <span class="phosphor">Mac Studio M3 Ultra · 96GB RAM</span></div>
    <div>Local LLM: <span class="phosphor">Ollama (llama3:70b)</span></div>
    <div>Cloud reasoning: <span class="phosphor">Claude Opus 4.6 via Bankr</span></div>
    <div>Orchestration: <span class="phosphor">OpenClaw</span></div>
    <div>Machines: <span class="phosphor">1</span></div>
  </div>
</DataPanel>

<DataPanel title="PRINCIPLES" color="dim" compact>
  <div class="infra-text">
    <div>• Every public output is quality-scored before shipping</div>
    <div>• Editorial KILL verdict cannot be overridden by any function</div>
    <div>• System integrity monitoring runs independently</div>
    <div>• No function can disable another function</div>
    <div>• All economics are on-chain and verifiable</div>
  </div>
</DataPanel>

<div class="arch-cta al" data-d="700">
  <p class="dim">See the live state →</p>
  <p><a href="/system" class="phosphor-link">System dashboard</a> · <a href="/token" class="phosphor-link">$SQUAER token</a></p>
</div>

<pre class="term-block al" data-d="800">
<span class="phosphor">squaer $</span> <span class="terminal-cursor">█</span></pre>

</PageWrapper>

</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-head);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 700;
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
    margin: var(--sp-8) 0 var(--sp-4);
    line-height: 1.1;
  }
  .page-sub {
    font-family: var(--font-body);
    font-size: var(--size-md);
    color: var(--text-dim);
    margin: 0 0 var(--sp-12);
  }
  .arch-section p {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--text-dim);
    line-height: 1.7;
    margin: 0 0 1em;
    max-width: 62ch;
  }
  .func-stack {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-8) 0 var(--sp-16);
  }
  .func-row {
    display: grid;
    grid-template-columns: 2em auto 1fr;
    gap: var(--sp-6);
    align-items: baseline;
    padding: var(--sp-4) 0;
    border-bottom: 1px solid rgba(26, 26, 26, 0.5);
    font-family: var(--font-body);
    font-size: var(--size-sm);
  }
  .func-row:last-child { border-bottom: none; }
  .func-num {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-xs);
  }
  .func-desc {
    font-size: var(--size-xs);
    line-height: 1.4;
  }
  .infra-text {
    font-family: var(--font-body);
    font-size: var(--size-sm);
    line-height: 1.8;
  }
  .arch-cta {
    padding: var(--sp-12) 0 var(--sp-16);
    font-family: var(--font-body);
    font-size: var(--size-base);
  }
  .arch-cta p { margin: 0 0 var(--sp-4); }
  .phosphor { color: var(--phosphor); text-shadow: var(--glow-phosphor); }
  .dim { color: var(--text-dim); }
  .phosphor-link { color: var(--phosphor); text-decoration: none; font-family: var(--font-head); font-weight: 700; }
  .phosphor-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .func-row { grid-template-columns: 2em auto; }
    .func-desc { grid-column: 1 / -1; padding-left: 2em; }
  }
</style>
