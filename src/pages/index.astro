---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import BlockLogo from '../components/BlockLogo.astro';

// Calculate uptime from known operational date
const opSince = '2026-02-03';
const uptimeMs = Date.now() - new Date(opSince).getTime();
const uptimeDays = Math.floor(uptimeMs / 86400000);
---

<BaseLayout title="ZERO OS" current="/">
  <div class="terminal-grid">
    <!-- ═══ LEFT TOP: BOOT SEQUENCE ═══ -->
    <div class="panel glyph-panel" id="boot-panel">
      <div class="boot-seq">
        <div class="bl" data-d="0"><span class="dim">BIOS POST ............</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="200"><span class="dim">MEM TEST:</span> <span class="phosphor-g">██████████</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="400"><span class="dim">GPU CORES:</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="600">&nbsp;</div>
        <div class="bl" data-d="700"><h1 class="sr-only">ZERO OS</h1><BlockLogo /></div>
        <div class="bl" data-d="900"><span class="dim glitch-text">⟨◇⟩ AUTONOMOUS TRADING SYSTEM</span></div>
        <div class="bl" data-d="1100">&nbsp;</div>
        <div class="bl" data-d="1200"><span class="dim">&gt;</span> MOUNT /cluster/memory <span class="boot-dots">........</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="1400"><span class="dim">&gt;</span> INIT SIGNAL ENGINE <span class="boot-dots">..........</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="1600"><span class="dim">&gt;</span> CONNECT HYPERLIQUID <span class="boot-dots">........</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="1800"><span class="dim">&gt;</span> START LOCAL LLM ENGINE <span class="boot-dots">......</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="2000">&nbsp;</div>
        <div class="bl" data-d="2100"><span class="amber-g">SYSTEM PROCESSES:</span></div>
        <div class="bl" data-d="2300">&nbsp; SUPERVISOR  <span class="boot-dots">.....</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="2500">&nbsp; EVALUATOR   <span class="boot-dots">....</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="2700">&nbsp; IMMUNE      <span class="boot-dots">.....</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="2900">&nbsp;</div>
        <div class="bl" data-d="3000"><strong style="color: var(--text);">Autonomous signal evaluation → execution on Hyperliquid.</strong></div>
        <div class="bl" data-d="3200"><span class="dim">Measurement period: March 21 – April 4, 2026</span></div>
        <div class="bl" data-d="3400"><span class="amber-g">Day {uptimeDays} of operation.</span></div>
        <div class="bl" data-d="3600"><span class="cursor-blink terminal-cursor"></span></div>
      </div>
    </div>

    <!-- ═══ STATUS ═══ -->
    <div class="panel status-panel">
      <h2 class="panel-title phosphor">STATUS</h2>
      <pre class="live-dash">{`UPTIME ................. ${uptimeDays}d
VENUE .................. Hyperliquid
PROCESSES .............. 3
MEASUREMENT PERIOD ..... active

Performance data available April 4.`}</pre>
    </div>

    <!-- ═══ THESIS ═══ -->
    <div class="panel what-panel">
      <h2 class="panel-title">THE THESIS</h2>
      <p style="font-size: var(--size-base); margin-bottom: var(--sp-10);">
        An autonomous trading system that evaluates signals, manages risk, and executes on Hyperliquid — without human intervention in trade decisions.
      </p>
      <p style="font-size: var(--size-base); margin-bottom: var(--sp-10);">
        Currently in a 14-day measurement period. No claims about performance until the data exists. The wallet is public. Check the work.
      </p>
      <p style="font-size: var(--size-md); margin-bottom: var(--sp-10);">
        <strong class="glow-breathe typewriter" style="color: var(--phosphor);">We are not asking you to believe us. We are asking you to check.</strong>
      </p>
      <div style="margin-top: var(--sp-12); font-size: var(--size-sm); color: var(--text-dim);">
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/manifesto" style="color: var(--phosphor); font-weight: 700;">Read the manifesto</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/token" style="color: var(--text);">Understand $SQUAER</a>
      </div>
    </div>

    <!-- ═══ ARCHITECTURE ═══ -->
    <div class="panel stagger-in mesh-panel">
      <h2 class="panel-title ice">ARCHITECTURE</h2>
      <pre class="live-dash" style="color: var(--text-dim);">{`SUPERVISOR ... strategy refresh + orchestration
EVALUATOR .... signal evaluation (WebSocket)
IMMUNE ....... health monitor + desync detection

Mac Studio M3 Ultra · dedicated hardware
Ollama local LLM · Claude for reasoning`}</pre>
    </div>

    <!-- ═══ ON-CHAIN REVENUE ═══ -->
    <div class="panel stagger-in revenue-panel">
      <h2 class="panel-title phosphor">ON-CHAIN REVENUE</h2>
      <pre class="live-dash" id="live-revenue">{`LP Commissions ..... $32,340
24h Volume ......... loading...
Token Price ........ loading...`}</pre>
      <div style="font-size: 0.6rem; margin-top: 4px; color: var(--text-dim);">
        Uniswap V4 LP · Base L2 · <a href="https://dexscreener.com/base/0x1d201b9760e79e058f3eaaddcb2cf777fbfdca39597c972b4e783acdfbf77ed6" target="_blank" rel="noopener" style="color: var(--text-dim);">verify →</a>
      </div>
    </div>

    <!-- ═══ VERIFY (full width) ═══ -->
    <div class="panel email-panel">
      <h2 class="panel-title amber">VERIFY EVERYTHING</h2>
      <p class="email-desc">No claims without sources. The wallet is public. The code is open.</p>
      <div class="wallet-block">
        <div class="wallet-label">TRADING WALLET (Hyperliquid)</div>
        <code class="wallet-addr">0xC7b52216e7BC13de0cd010aa12CAcb6D774453a2</code>
        <div class="wallet-note">Query on-chain: positions, fills, P&L — all public</div>
      </div>
      <div style="margin-top: var(--sp-12); font-size: var(--size-sm); color: var(--text-dim);">
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="https://app.hyperliquid.xyz/explorer/address/0xC7b52216e7BC13de0cd010aa12CAcb6D774453a2" target="_blank" rel="noopener" style="color: var(--phosphor); font-weight: 700;">HL Explorer — live positions & trades</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="https://dexscreener.com/base/0x1d201b9760e79e058f3eaaddcb2cf777fbfdca39597c972b4e783acdfbf77ed6" target="_blank" rel="noopener" style="color: var(--text);">LP revenue on DexScreener</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/token" style="color: var(--text);">$SQUAER contract + market</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/journal" style="color: var(--text);">Operating record</a>
      </div>
    </div>
  </div>
</BaseLayout>



<style>
  /* ═══ GRID LAYOUT ═══ */
  @media (min-width: 1200px) {
    .terminal-grid {
      grid-template-columns: 2fr 1.5fr 1fr;
      grid-template-rows: auto;
    }
    #boot-panel    { grid-column: 1; grid-row: 1; }
    .what-panel    { grid-column: 1; grid-row: 2; }
    .status-panel  { grid-column: 2; grid-row: 1; }
    .mesh-panel    { grid-column: 2; grid-row: 2; }
    .revenue-panel { grid-column: 3; grid-row: 1 / 3; }
    .email-panel   { grid-column: 1 / -1; }

    .revenue-panel { border-left: 1px solid #1a1a1a; }
    .status-panel  { border-left: 1px solid #1a1a1a; }
    .mesh-panel    { border-left: 1px solid #1a1a1a; }
  }

  @media (min-width: 641px) and (max-width: 1199px) {
    #boot-panel { grid-column: 1 / -1; }
  }

  /* Boot sequence */
  .boot-seq {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    line-height: 1.5;
  }
  .bl {
    opacity: 0;
    transform: translateY(3px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .bl.on {
    opacity: 1;
    transform: translateY(0);
  }
  .phosphor-g {
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
  }
  .amber-g {
    color: var(--amber);
    text-shadow: var(--glow-amber);
  }
  .boot-dots {
    color: var(--text-dim);
  }

  #boot-panel {
    animation: screenOn 0.3s ease-out;
  }
  @keyframes screenOn {
    0% { opacity: 0; filter: brightness(3); }
    30% { opacity: 1; filter: brightness(2); }
    50% { opacity: 0.8; filter: brightness(1.5); }
    100% { opacity: 1; filter: brightness(1); }
  }

  .live-dash {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    line-height: 1.6;
    color: var(--phosphor);
    text-shadow: 0 0 4px var(--phosphor-glow);
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }
  h1.bl { margin: 0; font-size: var(--size-sm); font-family: var(--font-head); font-weight: 700; line-height: 1.5; }
  h2.panel-title { margin: 0; margin-bottom: var(--sp-6); }

  /* Wallet block */
  .wallet-block {
    margin-top: var(--sp-10);
    padding: var(--sp-8);
    border: 1px solid var(--phosphor);
    background: rgba(200, 255, 0, 0.02);
  }
  .wallet-label {
    font-family: var(--font-head);
    font-size: var(--size-xs);
    color: var(--phosphor);
    letter-spacing: 0.06em;
    margin-bottom: var(--sp-4);
  }
  .wallet-addr {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    color: var(--text);
    word-break: break-all;
    line-height: 1.5;
    display: block;
    user-select: all;
  }
  .wallet-note {
    font-family: var(--font-body);
    font-size: var(--size-xs);
    color: var(--text-dim);
    margin-top: var(--sp-4);
  }

  @media (max-width: 640px) {
    .live-dash { font-size: var(--size-xs); }
    h1.bl { font-size: var(--size-xs); }
    .wallet-addr { font-size: var(--size-xs); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var lines = document.querySelectorAll('.bl');
    for (var i = 0; i < lines.length; i++) {
      (function(el) {
        var d = parseInt(el.getAttribute('data-d') || '0', 10);
        setTimeout(function() { el.classList.add('on'); }, d);
      })(lines[i]);
    }
  });
</script>

<script>
  // === LIVE REVENUE TICKER ===
  const TOTAL_REVENUE = 32340;
  async function updateRevenue() {
    const el = document.getElementById('live-revenue');
    if (!el) return;
    try {
      const res = await fetch('/svc/revenue.json');
      const data = await res.json();
      const rev = '$' + (data.lp_commissions_total || TOTAL_REVENUE).toLocaleString();
      const vol = data.volume_24h ? '$' + Math.round(data.volume_24h).toLocaleString() : '—';
      const price = data.token_price_usd ? '$' + data.token_price_usd.toFixed(6) : '—';
      el.textContent = `LP Commissions ..... ${rev}\n24h Volume ......... ${vol}\nToken Price ........ ${price}\n\nSource: Uniswap V4 LP · Base L2`;
    } catch(e) {
      el.textContent = `LP Commissions ..... $${TOTAL_REVENUE.toLocaleString()}\n24h Volume ......... —\nToken Price ........ —\n\nSource: Uniswap V4 LP · Base L2`;
    }
  }
  updateRevenue();
</script>

<script>
  // === BOOT SEQUENCE ORCHESTRATION ===
  (function() {
    var REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var bootSeen = sessionStorage.getItem('boot-seen');
    var allAfterBoot = Array.from(document.querySelectorAll('.terminal-grid > *:not(#boot-panel)'));

    if (REDUCED) return;

    allAfterBoot.forEach(function(el) {
      el.style.opacity = '0';
      el.style.visibility = 'hidden';
      el.style.transition = 'opacity 0.2s ease, visibility 0s';
    });

    function revealPanels(baseDelay) {
      allAfterBoot.forEach(function(el, i) {
        var delay = baseDelay + i * 200;
        setTimeout(function() {
          el.style.opacity = '1';
          el.style.visibility = 'visible';
        }, delay);
      });
      sessionStorage.setItem('boot-seen', '1');
    }

    if (bootSeen) {
      revealPanels(500);
    } else {
      revealPanels(3800);
    }
  })();
</script>
