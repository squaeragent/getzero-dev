<script>
  // === LIVE REVENUE TICKER (direct DexScreener — no SSR needed) ===
  let lastRevenueUpdate = 0;
  const PAIR_ADDR = '0x1d201b9760e79e058f3eaaddcb2cf777fbfdca39597c972b4e783acdfbf77ed6';
  const TOTAL_REVENUE = 33343; // LP commissions earned — updated by cron

  async function updateRevenue() {
    const el = document.getElementById('live-revenue');
    if (!el) return;
    try {
      const res = await fetch('/svc/revenue.json');
      const data = await res.json();
      lastRevenueUpdate = Date.now();
      const rev = '$' + (data.lp_commissions_total || TOTAL_REVENUE).toLocaleString();
      const vol = data.volume_24h ? '$' + Math.round(data.volume_24h).toLocaleString() : '—';
      const price = data.token_price_usd ? '$' + data.token_price_usd.toFixed(6) : '—';
      el.textContent = `LP Commissions ..... ${rev}\n24h Volume ......... ${vol}\nToken Price ........ ${price}\n\nSource: Uniswap V4 LP · Base L2 · updates every 60s`;
    } catch(e) {
      el.textContent = `LP Commissions ..... $${TOTAL_REVENUE.toLocaleString()}\n24h Volume ......... —\nToken Price ........ —\n\nSource: Uniswap V4 LP · Base L2 · updates every 60s`;
    }
  }

  // === LIVE ACTIVITY FEED ===
  let lastFeedUpdate = 0;

  // Junk filter: strip debug commands, internal noise, raw IDs
  function isCleanEvent(entry) {
    const action = (entry.action || entry.activity || '').toLowerCase();
    if (action.includes('--get-tweet')) return false;
    if (action.includes('--delete')) return false;
    if (action.startsWith('posted:') && /^\d{10,}/.test(action.replace('posted:', '').trim())) return false;
    if (action.includes('debug') || action.includes('test ping')) return false;
    if (action.length < 10) return false; // too short to be meaningful
    return true;
  }

  // Truncate action text for display
  function cleanAction(text) {
    if (text.length > 72) return text.slice(0, 69) + '...';
    return text;
  }

  async function updateFeed() {
    try {
      const res = await fetch('/svc/feed.json');
      const raw = await res.json();
      lastFeedUpdate = Date.now();
      const container = document.getElementById('live-feed');
      const entries = raw.events || raw.entries || raw;
      if (!container || !entries?.length) return;

      // Sort by timestamp descending (most recent first)
      const sorted = [...entries].sort((a, b) => {
        const ta = new Date(a.ts || a.time || a.timestamp || 0).getTime();
        const tb = new Date(b.ts || b.time || b.timestamp || 0).getTime();
        return tb - ta;
      });

      // Filter junk + take only 3 clean events
      const clean = sorted.filter(isCleanEvent).slice(0, 3);
      if (!clean.length) return;

      let lines = [];
      for (const entry of clean) {
        const t = new Date(entry.ts || entry.time || entry.timestamp);
        const now = new Date();
        const diffMin = Math.round((now - t) / 60000);
        let ago;
        if (diffMin < 1) ago = 'now';
        else if (diffMin < 60) ago = diffMin + 'm ago';
        else if (diffMin < 1440) ago = Math.floor(diffMin / 60) + 'h ago';
        else ago = Math.floor(diffMin / 1440) + 'd ago';

        const agent = (entry.agent || 'SYSTEM').toUpperCase();
        const action = cleanAction(entry.action || entry.activity || '');
        lines.push(`  ${ago.padEnd(7)} ${agent.padEnd(10)} ${action}`);
      }
      container.textContent = lines.join('\n');
    } catch(e) {}
  }

  // === UPDATED TIMER ===
  function tickUpdated() {
    const el = document.getElementById('live-updated');
    if (!el || !lastFeedUpdate) return;
    const ago = Math.round((Date.now() - lastFeedUpdate) / 1000);
    el.textContent = `Updated ${ago}s ago`;
  }

  // Init
  updateRevenue();
  updateFeed();
  setInterval(updateRevenue, 60000);
  setInterval(updateFeed, 30000);
  setInterval(tickUpdated, 1000);
</script>

<script>
  // === BOOT SEQUENCE ORCHESTRATION ===
  // Panels after boot should wait until boot animation completes
  (function() {
    var REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var bootSeen = sessionStorage.getItem('boot-seen');
    var allAfterBoot = Array.from(document.querySelectorAll('.terminal-grid > *:not(#boot-panel)'));

    if (REDUCED) {
      // Show everything immediately
      return;
    }

    // Hide all panels after boot
    allAfterBoot.forEach(function(el) {
      el.style.opacity = '0';
      el.style.visibility = 'hidden';
      el.style.transition = 'opacity 0.2s ease, visibility 0s';
    });

    function revealPanels(baseDelay) {
      allAfterBoot.forEach(function(el, i) {
        var delay = baseDelay + i * 200;
        setTimeout(function() {
          el.style.opacity = '1';
          el.style.visibility = 'visible';
        }, delay);
      });
      sessionStorage.setItem('boot-seen', '1');
    }

    if (bootSeen) {
      // Returning visitor — quick 500ms fade
      revealPanels(500);
    } else {
      // First visit — wait for boot sequence to finish (last line at 4300ms + buffer)
      revealPanels(4500);
    }
  })();
</script>

<script>
  // === COGNITIVE MESH — live agent status ===
  (function() {
    var meshAgents = document.querySelectorAll('.mesh-agent[data-mesh-agent]');
    if (!meshAgents.length) return;

    async function updateMesh() {
      try {
        var res = await fetch('/svc/status.json');
        var data = await res.json();
        var agents = data?.agents || {};
        var feed = data?.recent_activity || [];

        meshAgents.forEach(function(el) {
          var name = el.getAttribute('data-mesh-agent');
          var info = agents[name];
          var dot = el.querySelector('.mesh-dot');
          var act = el.querySelector('.mesh-act');
          if (!dot || !act) return;

          if (!info) {
            dot.setAttribute('data-intensity', 'resting');
            act.textContent = '—';
            return;
          }

          // Determine intensity from last active time
          var lastActive = info.lastActive || info.last_active;
          if (lastActive) {
            var mins = (Date.now() - new Date(lastActive).getTime()) / 60000;
            if (mins < 5) dot.setAttribute('data-intensity', 'intense');
            else if (mins < 30) dot.setAttribute('data-intensity', 'active');
            else if (mins < 120) dot.setAttribute('data-intensity', 'resting');
            else dot.setAttribute('data-intensity', 'offline');
          }

          // Show last activity
          var activity = info.activity || info.last_action || info.status || '—';
          act.textContent = activity.length > 20 ? activity.substring(0, 20) + '…' : activity;
        });
      } catch(e) {}
    }

    // Initial + interval
    setTimeout(updateMesh, 2000);
    setInterval(updateMesh, 30000);
  })();
</script>

