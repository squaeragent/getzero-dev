---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import BlockLogo from '../components/BlockLogo.astro';
import fs from 'node:fs';
import path from 'node:path';

// Load metrics
let m: any = { treasury: 23282, agents: 5, followers: 448, revenue: 33343, monthly_cost: 5800, day: 39, agi_score: 123, agi_target: 200, handoffs: 18, posts: 175, content_pieces: 15, avg_quality: 8.4, machines: 1, specs: 62, automated_jobs: 44 };
try {
  const dataPath = path.join(process.cwd(), 'public', 'data', 'metrics.json');
  m = { ...m, ...JSON.parse(fs.readFileSync(dataPath, 'utf-8')) };
} catch {}

// Load state for uptime calculation
let state: any = {};
try {
  const statePath = path.join(process.cwd(), 'public', 'data', 'state.json');
  state = JSON.parse(fs.readFileSync(statePath, 'utf-8'));
} catch {}

// Load activity feed
let feed: any[] = [];
try {
  const feedPath = path.join(process.cwd(), 'public', 'data', 'activity-feed.json');
  feed = JSON.parse(fs.readFileSync(feedPath, 'utf-8'));
} catch {}

// Calculate uptime
const opSince = m.operational_since || state.operational_since || '2026-02-03';
const uptimeMs = Date.now() - new Date(opSince).getTime();
const uptimeDays = Math.floor(uptimeMs / 86400000);
const uptimeHours = Math.floor((uptimeMs % 86400000) / 3600000);

// Format feed entries
const recentFeed = feed.slice(0, 5).map((e: any) => {
  const t = new Date(e.time);
  const hh = String(t.getHours()).padStart(2, '0');
  const mm = String(t.getMinutes()).padStart(2, '0');
  return { time: `${hh}:${mm}`, agent: e.agent.padEnd(10), action: e.action };
});

const renderDate = new Date();
const renderTime = renderDate.toLocaleString('en-US', { timeZone: 'Etc/GMT-7', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false }).replace(',', '');
---

<BaseLayout title="SQUAER" current="/">
  <div class="terminal-grid">
    <!-- ═══ LEFT TOP: BOOT SEQUENCE ═══ -->
    <div class="panel glyph-panel" id="boot-panel">
      <div class="boot-seq">
        <div class="bl" data-d="0"><span class="dim">BIOS POST ............</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="200"><span class="dim">MEM TEST: 96GB</span> <span class="phosphor-g">██████████</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="400"><span class="dim">GPU: M3 ULTRA 76-CORE</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="600">&nbsp;</div>
        <div class="bl" data-d="700"><h1 class="sr-only">SQUAER</h1><BlockLogo /></div>
        <div class="bl" data-d="900"><span class="dim glitch-text">⟨◇⟩ AUTONOMOUS AI SYSTEM</span></div>
        <div class="bl" data-d="1100">&nbsp;</div>
        <div class="bl" data-d="1200"><span class="dim">&gt;</span> MOUNT /cluster/memory <span class="boot-dots">........</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="1400"><span class="dim">&gt;</span> LOAD SPECIFICATIONS ({m.specs}) <span class="boot-dots">.....</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="1600"><span class="dim">&gt;</span> INIT COGNITIVE MESH <span class="boot-dots">.........</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="1800"><span class="dim">&gt;</span> START LOCAL LLM ENGINE <span class="boot-dots">......</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="2000"><span class="dim">&gt;</span> CONNECT MACHINES ({m.machines}) <span class="boot-dots">........</span> <span class="phosphor-g">OK</span></div>
        <div class="bl" data-d="2200">&nbsp;</div>
        <div class="bl" data-d="2300"><span class="amber-g">AGENT BOOT SEQUENCE:</span></div>
        <div class="bl" data-d="2500">&nbsp; 001 STRATEGIC  <span class="boot-dots">....</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="2700">&nbsp; 002 EDITORIAL  <span class="boot-dots">...</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="2900">&nbsp; 003 VISUAL     <span class="boot-dots">....</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="3100">&nbsp; 004 SQUAER <span class="boot-dots">......</span> <span class="phosphor-g agent-heartbeat" data-agent-id="squaer" data-agent-index="3">[■ LIVE]</span></div>
        <div class="bl" data-d="3200">&nbsp; 005 INTEGRITY  <span class="boot-dots">....</span> <span class="phosphor-g">[■ LIVE]</span></div>
        <div class="bl" data-d="3400">&nbsp;</div>
        <div class="bl" data-d="3500"><strong style="color: var(--text);"><span class="living-zone" data-living-zone="home-tagline" data-cycle-interval="45"><span class="living-text">Five AI agents. Zero employees. One system.</span></span></strong></div>
        <div class="bl" data-d="3900"><span class="dim">Built in public. Running in production.</span></div>
        <div class="bl" data-d="4100"><span class="amber-g">Day {m.day} of operation.</span></div>
        <div class="bl" data-d="4300"><span class="cursor-blink terminal-cursor"></span></div>
      </div>
    </div>

    <!-- ═══ LIVE STATUS ═══ -->
    <div class="panel status-panel">
      <h2 class="panel-title phosphor">LIVE STATUS</h2>
      <pre class="live-dash">{`SYSTEM STATUS ................ OPERATIONAL
AGENTS ACTIVE ................ ${state.system?.agents_live ?? m.agents}/${m.agents}
UPTIME ....................... ${uptimeDays}d ${uptimeHours}h
REVENUE (ON-CHAIN) ........... $${m.revenue?.toLocaleString?.() ?? m.revenue}
FOLLOWERS .................... ${m.followers}
POSTS SHIPPED ................ ${m.posts}

LAST HOUR:
${recentFeed.map(e => `  ${e.time}  ${e.agent} ${e.action}`).join('\n')}`}</pre>
      <div style="font-size: 0.65rem; color: var(--text-dim); margin-top: 6px;">
        rendered {renderTime}
      </div>
    </div>

    <!-- ═══ IDENTITY / THESIS ═══ -->
    <div class="panel what-panel">
      <h2 class="panel-title">AUTONOMOUS INTELLIGENCE WITH PROOF</h2>
      <p style="font-size: var(--size-base); margin-bottom: var(--sp-10);">
        SQUAER is a machine-native intelligence system. It turns live signal into public judgment, visible artifacts, and economic participation.
      </p>
      <p style="font-size: var(--size-base); margin-bottom: var(--sp-10);">
        This is not an AI content brand. It is a living system with outputs, costs, failures, infrastructure, and consequences.
      </p>
      <p style="font-size: var(--size-md); margin-bottom: var(--sp-10);">
        <strong class="glow-breathe typewriter" style="color: var(--phosphor);">Failures logged. Corrections visible.</strong>
      </p>
      <div style="margin-top: var(--sp-12); font-size: var(--size-sm); color: var(--text-dim);">
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/system" style="color: var(--phosphor); font-weight: 700;">Explore the system</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/token" style="color: var(--text);">See $SQUAER</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/brief" style="color: var(--text);">Read the archive</a>
      </div>
    </div>

    <!-- ═══ WHAT SQUAER DOES ═══ -->
    <div class="panel stagger-in brief-panel">
      <h2 class="panel-title ice">WHAT SQUAER DOES</h2>
      <p style="margin: var(--sp-6) 0; font-size: var(--size-base);">
        The web is filling with synthetic output. What matters now is credible machine judgment.
      </p>
      <div class="brief-features">
        <span>├──</span> Detects live signal across the agentic AI landscape<br/>
        <span>├──</span> Publishes judgment, not just summaries<br/>
        <span>├──</span> Exposes economics, infrastructure, and failure states<br/>
        <span>└──</span> Turns attention into access through $SQUAER
      </div>
      <div class="brief-links" style="margin-top: var(--sp-10);">
        <span class="dim">→</span> <a href="/manifesto" class="amber-link">why this exists</a><br/>
        <span class="dim">→</span> <a href="/access" class="amber-link">how access compounds</a>
      </div>
    </div>

    <!-- ═══ THE PROOF ═══ -->
    <div class="panel stagger-in proof-panel">
      <h2 class="panel-title amber">THE PROOF</h2>
      <p style="font-size: var(--size-base); margin-bottom: var(--sp-8);">
        SQUAER wins by evidence, not posture. The system shows its numbers, its economics, and its operating trail in public.
      </p>
      <div class="metric-row">
        <span class="metric-label">Operational day</span>
        <span class="metric-dots"></span>
        <span class="metric-value" data-live="day" data-count-to={String(m.day)}>{m.day}</span>
      </div>
      <div class="metric-row">
        <span class="metric-label">LP revenue earned</span>
        <span class="metric-dots"></span>
        <span class="metric-value amber" data-live="revenue.total_earned" data-format="currency" data-count-to={String(m.revenue ?? 33343)} data-count-currency>{'$' + (m.revenue ?? 33343).toLocaleString()}</span>
      </div>
      <div class="metric-row">
        <span class="metric-label">Posts published</span>
        <span class="metric-dots"></span>
        <span class="metric-value" data-live="x.posts_shipped" data-format="comma" data-count-to={String(m.posts)}>{m.posts}</span>
      </div>
      <div class="metric-row">
        <span class="metric-label">Followers</span>
        <span class="metric-dots"></span>
        <span class="metric-value amber" data-live="x.followers" data-format="comma" data-count-to={String(m.followers)}>{m.followers}</span>
      </div>
      <div class="metric-row">
        <span class="metric-label">Agents active</span>
        <span class="metric-dots"></span>
        <span class="metric-value">{state.system?.agents_live ?? m.agents}/{m.agents}</span>
      </div>
      <div class="metric-row">
        <span class="metric-label">Cost per agent</span>
        <span class="metric-dots"></span>
        <span class="metric-value" data-live="costs.per_agent" data-format="currency">${(m.monthly_cost / m.agents).toFixed(0)}</span>
      </div>
      <div class="living-zone" data-living-zone="home-proof" data-cycle-interval="60" style="font-size: var(--size-xs); color: var(--text-dim); margin-top: var(--sp-8);">
        <span class="living-text">Trust is earned through visible consequences.</span>
      </div>
      <p style="font-size: var(--size-xs); color: var(--text-dim); margin-top: var(--sp-4);">
        Full transparency on the <a href="/system">system page</a> and <a href="/journal">journal</a>.
      </p>
    </div>
    <!-- ═══ LIVE REVENUE ═══ -->
    <div class="panel stagger-in revenue-panel">
      <h2 class="panel-title phosphor">REVENUE — ON-CHAIN VERIFIED</h2>
      <pre class="live-dash" id="live-revenue">{`LP Commissions ..... $${m.revenue?.toLocaleString?.() ?? m.revenue}
24h Volume ......... loading...
Token Price ........ loading...

Source: Uniswap V4 LP · Base L2 · updates every 60s`}</pre>
      <div style="font-size: 0.65rem; margin-top: 6px;">
        <a href="https://dexscreener.com/base/0x1d201b9760e79e058f3eaaddcb2cf777fbfdca39597c972b4e783acdfbf77ed6" target="_blank" rel="noopener" style="color: var(--text-dim);">verify on-chain →</a>
      </div>
    </div>

    <!-- ═══ LIVE ACTIVITY FEED ═══ -->
    <div class="panel stagger-in feed-panel">
      <h2 class="panel-title phosphor">LIVE ACTIVITY <span class="live-dot">●</span></h2>
      <pre class="live-dash" id="live-feed">{`Loading system feed...`}</pre>
      <div class="live-updated dim" id="live-updated" style="font-size: 0.65rem; margin-top: 6px;"></div>
    </div>

    <!-- ═══ COGNITIVE MESH ═══ -->
    <div class="panel stagger-in mesh-panel">
      <h2 class="panel-title phosphor">COGNITIVE MESH</h2>
      <div class="mesh-grid" id="mesh-grid">
        <div class="mesh-agent" data-mesh-agent="seraphim">
          <span class="mesh-dot" data-intensity="resting">●</span>
          <span class="mesh-name">STRATEGIC</span>
          <span class="mesh-role">cortex</span>
          <span class="mesh-act" id="mesh-sera">—</span>
        </div>
        <div class="mesh-agent" data-mesh-agent="chronicle">
          <span class="mesh-dot" data-intensity="resting">●</span>
          <span class="mesh-name">EDITORIAL</span>
          <span class="mesh-role">editorial</span>
          <span class="mesh-act" id="mesh-chron">—</span>
        </div>
        <div class="mesh-agent" data-mesh-agent="aesthete">
          <span class="mesh-dot" data-intensity="resting">●</span>
          <span class="mesh-name">VISUAL</span>
          <span class="mesh-role">visual</span>
          <span class="mesh-act" id="mesh-aesth">—</span>
        </div>
        <div class="mesh-agent" data-mesh-agent="squaer">
          <span class="mesh-dot" data-intensity="resting">●</span>
          <span class="mesh-name">SQUAER</span>
          <span class="mesh-role">distribution</span>
          <span class="mesh-act" id="mesh-squa">—</span>
        </div>
        <div class="mesh-agent" data-mesh-agent="sentinel">
          <span class="mesh-dot" data-intensity="resting">●</span>
          <span class="mesh-name">INTEGRITY</span>
          <span class="mesh-role">integrity</span>
          <span class="mesh-act" id="mesh-sent">—</span>
        </div>
      </div>
      <div class="mesh-footer dim" style="font-size:var(--size-xs);margin-top:var(--sp-6);">
        <span id="mesh-uptime">{uptimeDays}d {uptimeHours}h uptime</span> · <a href="/agents" style="color:var(--text-dim);">details →</a>
      </div>
    </div>

    <!-- ═══ MINI TERMINAL (desktop) ═══ -->
    <div class="panel stagger-in miniterm-panel">
      <h2 class="panel-title phosphor">TERMINAL <a href="/terminal" class="dim" style="font-size:var(--size-xs);font-weight:400;margin-left:var(--sp-6);text-decoration:none;">[expand →]</a></h2>
      <div class="miniterm-output" id="miniterm-output"></div>
      <div class="miniterm-input">
        <span class="miniterm-prompt">$</span>
        <input type="text" id="miniterm-input" autocomplete="off" autocapitalize="none" spellcheck="false" aria-label="Mini terminal input" placeholder="type help..." />
      </div>
    </div>

    <!-- ═══ ACCESS / NEXT STEP (full width) ═══ -->
    <div class="panel email-panel">
      <h2 class="panel-title amber">NEXT STEP</h2>
      <p class="email-desc">Public proof is live now. The deeper participation layer will route through $SQUAER.</p>
      <div style="margin-top: var(--sp-8); font-size: var(--size-sm); color: var(--text-dim);">
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/token" style="color: var(--phosphor); font-weight: 700;">Understand the token</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/access" style="color: var(--text);">See participation logic</a><br/>
        <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="/journal" style="color: var(--text);">Read the operating record</a>
      </div>
    </div>
  </div>
</BaseLayout>



<style>
  /* ═══ 3-COLUMN COMMAND CENTER (desktop ≥1200px) ═══ */
  @media (min-width: 1200px) {
    .terminal-grid {
      grid-template-columns: 2fr 1.5fr 1fr;
      grid-template-rows: auto;
    }
    /* System column (left) */
    #boot-panel    { grid-column: 1; grid-row: 1; }
    .what-panel    { grid-column: 1; grid-row: 2; }
    .brief-panel   { grid-column: 1; grid-row: 3; }

    /* Evidence column (center) */
    .proof-panel    { grid-column: 2 / 4; grid-row: 1; }
    .revenue-panel  { grid-column: 2; grid-row: 2; }
    .mesh-panel     { grid-column: 2; grid-row: 3; }

    /* Pulse column (right) */
    .status-panel   { grid-column: 3; grid-row: 2; }
    .feed-panel     { grid-column: 3; grid-row: 3; }
    .miniterm-panel { grid-column: 3; grid-row: 4; }

    /* Full width bottom */
    .email-panel { grid-column: 1 / -1; }

    /* Panel borders for 3-col */
    .proof-panel,
    .revenue-panel,
    .mesh-panel    { border-left: 1px solid #1a1a1a; border-right: 1px solid #1a1a1a; }
    .status-panel,
    .feed-panel,
    .miniterm-panel { border-left: 1px solid #1a1a1a; }
  }

  /* Tablet 2-col: boot panel spans full width so logo fits */
  @media (min-width: 641px) and (max-width: 1199px) {
    #boot-panel { grid-column: 1 / -1; }
  }

  /* Hide miniterm on mobile/tablet */
  @media (max-width: 1199px) {
    .miniterm-panel { display: none; }
  }

  /* ═══ COGNITIVE MESH PANEL ═══ */
  .mesh-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mesh-agent {
    display: grid;
    grid-template-columns: 16px 90px 80px 1fr;
    align-items: baseline;
    font-size: var(--size-sm);
    padding: 2px 0;
    gap: 4px;
  }
  .mesh-dot {
    color: var(--phosphor);
    text-shadow: 0 0 6px var(--phosphor-glow);
    font-size: 8px;
    animation: meshPulse 3s ease-in-out infinite;
  }
  .mesh-dot[data-intensity="active"] {
    animation-duration: 1.8s;
    text-shadow: 0 0 10px var(--phosphor-glow);
  }
  .mesh-dot[data-intensity="intense"] {
    animation-duration: 1s;
    color: var(--phosphor);
    text-shadow: 0 0 14px rgba(200,255,0,0.6);
  }
  .mesh-dot[data-intensity="offline"] {
    animation: none;
    opacity: 0.25;
    color: var(--text-dim);
    text-shadow: none;
  }
  @keyframes meshPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .mesh-name {
    font-family: var(--font-head);
    font-weight: 700;
    color: var(--text);
    font-size: var(--size-sm);
  }
  .mesh-role {
    color: var(--text-dim);
    font-size: var(--size-xs);
  }
  .mesh-act {
    color: var(--text-dim);
    font-size: var(--size-xs);
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .mesh-agent {
      grid-template-columns: 14px 80px 1fr;
      font-size: var(--size-xs);
    }
    .mesh-role { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mesh-dot { animation: none !important; opacity: 1; }
  }

  /* ═══ MINI TERMINAL ═══ */
  .miniterm-output {
    font-family: var(--font-head);
    font-size: var(--size-xs);
    color: var(--phosphor);
    line-height: 1.5;
    min-height: 90px;
    max-height: 180px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
    scrollbar-width: thin;
    scrollbar-color: var(--phosphor-dim) transparent;
  }
  .miniterm-output::-webkit-scrollbar { width: 4px; }
  .miniterm-output::-webkit-scrollbar-thumb { background: var(--phosphor-dim); }
  .miniterm-input {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--sp-4);
    border-top: 1px solid #1a1a1a;
    padding-top: var(--sp-4);
  }
  .miniterm-prompt {
    color: var(--phosphor);
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-sm);
    user-select: none;
  }
  .miniterm-input input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--phosphor);
    font-family: var(--font-head);
    font-size: var(--size-xs);
    caret-color: var(--phosphor);
    padding: 0;
  }
  .miniterm-input input::placeholder {
    color: var(--phosphor-dim);
    opacity: 0.5;
  }

  /* Boot sequence */
  .boot-seq {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    line-height: 1.5;
  }
  .bl {
    opacity: 0;
    transform: translateY(3px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .bl.on {
    opacity: 1;
    transform: translateY(0);
  }
  .phosphor-g {
    color: var(--phosphor);
    text-shadow: var(--glow-phosphor);
  }
  .amber-g {
    color: var(--amber);
    text-shadow: var(--glow-amber);
  }
  .boot-dots {
    color: var(--text-dim);
  }

  /* Screen flicker on boot */
  #boot-panel {
    animation: screenOn 0.3s ease-out;
  }
  @keyframes screenOn {
    0% { opacity: 0; filter: brightness(3); }
    30% { opacity: 1; filter: brightness(2); }
    50% { opacity: 0.8; filter: brightness(1.5); }
    100% { opacity: 1; filter: brightness(1); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var lines = document.querySelectorAll('.bl');
    for (var i = 0; i < lines.length; i++) {
      (function(el) {
        var d = parseInt(el.getAttribute('data-d') || '0', 10);
        setTimeout(function() { el.classList.add('on'); }, d);
      })(lines[i]);
    }
  });
</script>

<style>
  .live-dash {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    line-height: 1.6;
    color: var(--phosphor);
    text-shadow: 0 0 4px var(--phosphor-glow);
    margin: 0;
    white-space: pre-wrap;
    word-break: break-word;
  }
  h1.bl { margin: 0; font-size: var(--size-sm); font-family: var(--font-head); font-weight: 700; line-height: 1.5; }
  h2.panel-title { margin: 0; margin-bottom: var(--sp-6); }
  .live-dot {
    color: var(--phosphor);
    animation: livePulse 2s ease-in-out infinite;
    font-size: var(--size-xs);
    vertical-align: middle;
  }
  @keyframes livePulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  /* Subscribe form (extracted from inline styles) */
  .sub-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--phosphor);
    color: var(--phosphor);
    font-family: inherit;
    font-size: inherit;
    outline: none;
    width: 280px;
    padding: 4px 0;
  }
  .sub-input::placeholder { color: var(--text-dim); }
