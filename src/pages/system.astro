---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import PageWrapper from '../components/ui/PageWrapper.astro';
import HazardDivider from '../components/ui/HazardDivider.astro';
import DataPanel from '../components/ui/DataPanel.astro';

const opSince = '2026-02-03';
const uptimeMs = Date.now() - new Date(opSince).getTime();
const uptimeDays = Math.floor(uptimeMs / 86400000);
---

<BaseLayout title="System — ZERO OS" description="Architecture and status of the ZERO OS autonomous trading system." current="/system" ogImage="/og/default.png">
  <section class="section container">
<PageWrapper size="wide" class="sys-wrap">
<h1 class="sr-only">System</h1>
<pre class="sys-prompt al" data-d="0"><span class="phosphor">zero $</span> diagnostics --full

● zero-os.service — ZERO OS
  Active: <span class="phosphor">active (running)</span>
  Uptime: {uptimeDays} days</pre>

<div class="scan-line al" data-d="300" id="scan-infra">⠋ Scanning infrastructure...</div>

<div class="al" data-d="800" id="section-top">
<div class="cmd-top-grid">

  <div class="cmd-col">
    <HazardDivider variant="section" text="INFRASTRUCTURE" color="phosphor" />
    <DataPanel title="PRIMARY NODE" status="● ONLINE" color="phosphor" compact>
      <div class="kv-row"><span class="kv-label">hardware</span> Mac Studio M3 Ultra 96GB</div>
      <div class="kv-row"><span class="kv-label">role</span> All operations (single machine)</div>
      <div class="kv-row"><span class="kv-label">services</span> OpenClaw · Ollama · Python 3.14</div>
      <div class="kv-row"><span class="kv-label">uptime</span> {uptimeDays} days</div>
    </DataPanel>

    <HazardDivider variant="section" text="TRADING SYSTEM" color="phosphor" />
    <div class="layer-stack">
      <div class="layer-row"><span class="layer-id">P1</span><span class="layer-name">SUPERVISOR</span><span class="phosphor">● LIVE</span></div>
      <div class="layer-row"><span class="layer-id">P2</span><span class="layer-name">EVALUATOR</span><span class="phosphor">● LIVE</span></div>
      <div class="layer-row"><span class="layer-id">P3</span><span class="layer-name">IMMUNE</span><span class="phosphor">● LIVE</span></div>
    </div>
    <div class="kv-row dim" style="margin-top: var(--sp-4);">
      Supervisor orchestrates strategy refresh every 2h.<br/>
      Evaluator processes signals via WebSocket in real time.<br/>
      Immune monitors health and detects position desync.
    </div>
  </div>

  <div class="cmd-col">
    <HazardDivider variant="section" text="SIGNAL PIPELINE" color="ice" />
    <DataPanel title="STRATEGY MANAGER" status="2h cycle" color="phosphor" compact>
      <div class="kv-row"><span class="kv-label">source</span> ENVY API (signal scoring + assembly)</div>
      <div class="kv-row"><span class="kv-label">universe</span> 8 coins (filtered from 37 candidates)</div>
      <div class="kv-row"><span class="kv-label">selection</span> Assembled strategy Sharpe (not individual signal)</div>
      <div class="kv-row"><span class="kv-label">floor</span> 1.5 minimum assembled Sharpe</div>
    </DataPanel>

    <DataPanel title="RISK GATES" status="9 checks" color="phosphor" compact>
      <div class="kv-row"><span class="kv-label">max positions</span> 3</div>
      <div class="kv-row"><span class="kv-label">capital floor</span> 60% of peak equity</div>
      <div class="kv-row"><span class="kv-label">daily loss limit</span> 7% of equity</div>
      <div class="kv-row"><span class="kv-label">funding check</span> reject if cost > 2%</div>
      <div class="kv-row"><span class="kv-label">liquidity check</span> reject if > 50% of book</div>
      <div class="kv-row"><span class="kv-label">alpha vs cost</span> reject if expected alpha &lt; fees</div>
      <div class="kv-row"><span class="kv-label">book depth</span> skip trade on zero depth</div>
      <div class="kv-row"><span class="kv-label">signal blacklist</span> SOCIAL, INFLUENCER, ARCH, CHAOS families</div>
      <div class="kv-row"><span class="kv-label">coin blacklist</span> negative portfolio Sharpe coins excluded</div>
    </DataPanel>
  </div>

</div>
</div>

<!-- ═══ MEASUREMENT PERIOD ═══ -->
<div class="scan-line al" data-d="1200" id="scan-measure">⠋ Checking measurement status...</div>

<div class="al" data-d="1700" id="section-measure">
<HazardDivider variant="warning" text="MEASUREMENT PERIOD" color="amber" />

<DataPanel title="14-DAY CODE FREEZE" status="ACTIVE" color="amber" compact>
  <div class="kv-row"><span class="kv-label">start</span> March 21, 2026</div>
  <div class="kv-row"><span class="kv-label">end</span> April 4, 2026</div>
  <div class="kv-row"><span class="kv-label">purpose</span> Measure system edge with no parameter changes</div>
  <div class="kv-row"><span class="kv-label">allowed</span> Infrastructure/safety fixes only</div>
  <div class="kv-row"><span class="kv-label">forbidden</span> Strategy changes, parameter tuning, signal adjustments</div>
</DataPanel>

<div style="margin-top: var(--sp-8); font-size: var(--size-sm); color: var(--text-dim);">
  Performance data will be published after the measurement period ends. Until then, verify the wallet directly.
</div>
</div>

<!-- ═══ VERIFY ═══ -->
<div class="scan-line al" data-d="2000" id="scan-verify">⠋ Loading verification links...</div>

<div class="al" data-d="2500" id="section-verify">
<HazardDivider variant="section" text="VERIFY" color="phosphor" />

<div class="wallet-block">
  <div class="wallet-label">TRADING WALLET (Hyperliquid)</div>
  <code class="wallet-addr">0xC7b52216e7BC13de0cd010aa12CAcb6D774453a2</code>
  <div class="wallet-note">Positions, fills, P&L — all publicly queryable on Hyperliquid</div>
</div>

<div style="margin-top: var(--sp-12); font-size: var(--size-sm); color: var(--text-dim);">
  <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="https://app.hyperliquid.xyz/explorer/address/0xC7b52216e7BC13de0cd010aa12CAcb6D774453a2" target="_blank" rel="noopener" style="color: var(--phosphor); font-weight: 700;">Hyperliquid Explorer</a><br/>
  <span class="phosphor" style="font-family: var(--font-head);">→</span> <a href="https://dexscreener.com/base/0x1d201b9760e79e058f3eaaddcb2cf777fbfdca39597c972b4e783acdfbf77ed6" target="_blank" rel="noopener" style="color: var(--text);">LP revenue on DexScreener</a>
</div>

<div class="sys-eof"><span class="phosphor">[EOF]</span></div>
</div>

</PageWrapper>
  </section>
</BaseLayout>

<style>
  .sys-wrap {}
  .sys-prompt {
    font-family: var(--font-body);
    color: var(--text-dim);
    padding: var(--sp-12) 0;
    font-size: var(--size-base);
    border: none;
    background: none;
    white-space: pre-wrap;
  }
  .sys-eof {
    padding: var(--sp-12) 0;
    font-family: var(--font-body);
    font-size: var(--size-base);
  }

  .scan-line {
    font-family: var(--font-body);
    font-size: var(--size-base);
    padding: var(--sp-6) 0;
    color: var(--text-dim);
    transition: opacity 0.25s ease, transform 0.25s ease, color 0.2s ease;
  }
  .scan-line.pass { color: var(--phosphor); font-weight: 700; }
  .scan-line.warn { color: var(--amber); font-weight: 700; }

  .cmd-top-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0 var(--sp-24);
  }
  @media (min-width: 900px) {
    .cmd-top-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .cmd-col { min-width: 0; }

  .layer-stack { margin: var(--sp-8) 0; }
  .layer-row {
    display: grid;
    grid-template-columns: 2em 10em auto;
    align-items: center;
    gap: var(--sp-6);
    padding: var(--sp-4) 0;
    border-bottom: 1px solid rgba(26, 26, 26, 0.5);
    font-family: var(--font-body);
    font-size: var(--size-sm);
  }
  .layer-row:last-child { border-bottom: none; }
  .layer-id {
    font-family: var(--font-head);
    font-weight: 700;
    color: var(--phosphor);
    font-size: var(--size-xs);
  }
  .layer-name {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: var(--size-xs);
    letter-spacing: 0.04em;
    color: var(--text);
  }

  .kv-row {
    padding: var(--sp-2) 0;
    color: var(--text);
    font-family: var(--font-body);
    font-size: var(--size-sm);
    line-height: 1.5;
  }
  .kv-label {
    display: inline-block;
    min-width: 8em;
    color: var(--text-dim);
    font-size: var(--size-xs);
  }

  .wallet-block {
    margin-top: var(--sp-10);
    padding: var(--sp-8);
    border: 1px solid var(--phosphor);
    background: rgba(200, 255, 0, 0.02);
  }
  .wallet-label {
    font-family: var(--font-head);
    font-size: var(--size-xs);
    color: var(--phosphor);
    letter-spacing: 0.06em;
    margin-bottom: var(--sp-4);
  }
  .wallet-addr {
    font-family: var(--font-head);
    font-size: var(--size-sm);
    color: var(--text);
    word-break: break-all;
    line-height: 1.5;
    display: block;
    user-select: all;
  }
  .wallet-note {
    font-family: var(--font-body);
    font-size: var(--size-xs);
    color: var(--text-dim);
    margin-top: var(--sp-4);
  }

  .ice { color: var(--ice); }
  .phosphor { color: var(--phosphor); }
  .amber { color: var(--amber); }
  .dim { color: var(--text-dim); }

  @media (max-width: 640px) {
    .layer-row {
      grid-template-columns: 2em 6em auto;
      gap: var(--sp-4);
      font-size: var(--size-xs);
    }
    .kv-label { min-width: 5em; }
    .kv-row { word-break: break-word; overflow-wrap: anywhere; }
    .wallet-addr { font-size: var(--size-xs); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var swaps = [
      { id: 'scan-infra', delay: 750, text: '[PASS] INFRASTRUCTURE + PROCESSES', cls: 'pass' },
      { id: 'scan-measure', delay: 1450, text: '[ACTIVE] MEASUREMENT PERIOD — March 21 to April 4', cls: 'warn' },
      { id: 'scan-verify', delay: 2150, text: '[PASS] VERIFICATION LINKS', cls: 'pass' },
    ];
    for (var j = 0; j < swaps.length; j++) {
      (function(s) {
        setTimeout(function() {
          var el = document.getElementById(s.id);
          if (el) { el.textContent = s.text; el.classList.add(s.cls); }
        }, s.delay);
      })(swaps[j]);
    }
  });
</script>
